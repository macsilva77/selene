# ── Stage 1: builder (install + build no mesmo stage para preservar bun cache) ─
FROM oven/bun:1 AS builder
WORKDIR /app

# Copiar manifests de todo o workspace
COPY package.json bun.lock ./
COPY apps/web/package.json ./apps/web/
COPY packages/ui/package.json ./packages/ui/
COPY packages/providers/package.json ./packages/providers/
COPY packages/trpc/package.json ./packages/trpc/
COPY backend/package.json ./backend/

# Instalar no mesmo stage (bun usa symlinks para cache global — não pode ser copiado entre stages)
ENV PUPPETEER_SKIP_DOWNLOAD=true
RUN bun install --frozen-lockfile

# Copiar fontes de todos os packages internos
COPY apps/web ./apps/web
COPY packages ./packages

# NEXT_PUBLIC_* precisam estar disponíveis no build time
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_TELEMETRY_DISABLED=1

# cd + bun run build: bun resolve next via workspace root node_modules
RUN cd apps/web && bun run build

# ── Stage 3: runner ───────────────────────────────────────────────────────────
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup -S nextjs && adduser -S nextjs -G nextjs

# standalone output — contém apenas o necessário para rodar
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nextjs /app/apps/web/public ./apps/web/public

USER nextjs
EXPOSE 3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "apps/web/server.js"]
