# ── terraform.tfvars ──────────────────────────────────────────────────────────
# ATENÇÃO: NÃO commite este arquivo com valores reais!
# Adicione terraform.tfvars ao .gitignore.
#
# Como preencher:
#   1. Crie o projeto GCP em console.cloud.google.com
#   2. Copie o "ID do projeto" (ex: selene-prod-123456)
#   3. Escolha uma senha forte para db_password e redis_auth_string

project_id = "SEU-PROJECT-ID-AQUI"

# Região São Paulo (padrão) — troque se necessário
# region = "southamerica-east1"

# Senha para o usuário 'selene' no Cloud SQL
db_password = "ESCOLHA-UMA-SENHA-FORTE-AQUI"

# Auth string Redis (mínimo 16 caracteres)
redis_auth_string = "ESCOLHA-UMA-AUTH-STRING-AQUI-16C"

# Chave AES-256 para criptografia de certificados A1 no banco (OBRIGATÓRIO)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
cert_encryption_key = "GERE-COM-O-COMANDO-ACIMA-64-CHARS-HEX"

# URL pública do frontend — usada pelo CORS da API
app_url = "https://SEU-FRONTEND.a.run.app"

# JWT secrets — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
jwt_secret         = "GERE-64-CHARS-HEX"
jwt_refresh_secret = "GERE-64-CHARS-HEX-DIFERENTE"

# SMTP (ex: Brevo, SendGrid, Gmail)
smtp_host = "smtp.brevo.com"
smtp_port = "587"
smtp_user = "SEU-EMAIL@dominio.com"
smtp_pass = "SUA-SENHA-SMTP"
smtp_from = "Selene <noreply@seudominio.com.br>"

# Senha do certificado PFX A1 (não obrigatório no setup inicial — pode deixar vazio)
sefaz_cert_password = ""
