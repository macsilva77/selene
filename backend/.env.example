# ============================================================
# SIGIC Backend — variáveis de ambiente
# Copie para .env e preencha com valores reais.
# NUNCA commite o arquivo .env no repositório.
# Em produção, injete via K8s External Secrets (ver infra/k8s/external-secrets.yaml).
# ============================================================

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://sigic:<SENHA_FORTE>@localhost:15432/sigic?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<SENHA_REDIS_FORTE>

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<256_BITS_HEX>
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=<256_BITS_HEX_DIFERENTE>
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=noreply@sigic.gov.br
SMTP_PASS=<SMTP_PASSWORD>
SMTP_FROM="SIGIC <noreply@sigic.gov.br>"

# Storage (S3-compatible / MinIO)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=sigic-documents
STORAGE_ACCESS_KEY=<MINIO_ACCESS_KEY>
STORAGE_SECRET_KEY=<MINIO_SECRET_KEY>
STORAGE_REGION=us-east-1

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Notification Engine Cron (UTC-3 => 00:05 AM = 03:05 UTC)
NOTIFICATION_CRON=5 3 * * *

# Audit log retention (days)
AUDIT_RETENTION_DAYS=1825
