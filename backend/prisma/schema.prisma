  usuarioId   String           @map("usuario_id")
  ordem       Int?
  obrigatorio Boolean          @default(true)
  tipo        TipoDocumentoReg @relation(fields: [tipoId], references: [id], onDelete: Cascade)
  usuario     Usuario          @relation(fields: [usuarioId], references: [id])

  @@unique([tipoId, usuarioId])
  @@map("workflow_signatarios_tipo_doc")
