// ── Certificados Digitais A1 ──────────────────────────────────────────────────

enum CertificadoStatus {
  ATIVO
  VENCIDO
  REVOGADO
  INVALIDO
  EXPIRACAO_PROXIMA
}

enum CertificadoAcao {
  UPLOAD
  ASSOCIACAO
  USO
  REMOCAO
  VISUALIZACAO
}

model CertificadoDigital {
  id             String               @id @default(uuid())
  tenantId       String               @map("tenant_id")
  razaoSocial    String               @map("razao_social")
  cnpjCert       String               @map("cnpj_cert")
  raizCnpj       String               @map("raiz_cnpj")
  numeroSerie    String               @map("numero_serie")
  autoridadeCert String               @map("autoridade_cert")
  dataEmissao    DateTime             @map("data_emissao")
  dataValidade   DateTime             @map("data_validade")
  thumbprint     String
  status         CertificadoStatus
  arquivoEnc     Bytes?               @map("arquivo_enc")
  storageIv      String?              @map("storage_iv")
  /// Certificado público em PEM, criptografado AES-256-GCM
  certPemEnc     Bytes?               @map("cert_pem_enc")
  certPemIv      String?              @map("cert_pem_iv")
  /// Chave privada em PEM, criptografada AES-256-GCM
  keyPemEnc      Bytes?               @map("key_pem_enc")
  keyPemIv       String?              @map("key_pem_iv")
  /// Senha do PFX original, criptografada AES-256-GCM (necessário para ReceitaNetBX/JSignNet)
  senhaEnc       Bytes?               @map("senha_enc")
  senhaIv        String?              @map("senha_iv")
  nomeArquivo    String?              @map("nome_arquivo")
  ativo          Boolean              @default(true)
  criadoEm      DateTime              @default(now()) @map("criado_em")
  atualizadoEm  DateTime              @updatedAt @map("atualizado_em")
  criadoPorId   String                @map("criado_por_id")

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  criadoPor     Usuario               @relation("CertCriadoPor", fields: [criadoPorId], references: [id])
  empresas      CertificadoEmpresa[]
  procuracao    ProcuracaoEletronica?
  logs          CertificadoLog[]
  dfeConfigs    DfeConfig[]

  @@unique([tenantId, thumbprint])
  @@index([tenantId, status])
  @@index([tenantId, raizCnpj])
  @@map("certificados_digitais")
}

model CertificadoEmpresa {
  certificadoId String             @map("certificado_id")
  empresaId     String             @map("empresa_id")
  associadoEm   DateTime           @default(now()) @map("associado_em")

  certificado   CertificadoDigital @relation(fields: [certificadoId], references: [id])
  empresa       Empresa            @relation(fields: [empresaId], references: [id])

  @@id([certificadoId, empresaId])
  @@map("certificados_empresas")
}

model ProcuracaoEletronica {
  id               String             @id @default(uuid())
  certificadoId    String             @unique @map("certificado_id")
  cnpjOutorgante   String             @map("cnpj_outorgante")
  cpfCnpjOutorgado String             @map("cpf_cnpj_outorgado")
  nomeOutorgado    String             @map("nome_outorgado")
  poderesDelegados String             @map("poderes_delegados")
  dataInicio       DateTime           @map("data_inicio")           @db.Date
  dataValidade     DateTime           @map("data_validade_proc")    @db.Date
  storageKey       String?            @map("storage_key")
  nomeArquivo      String?            @map("nome_arquivo")
  criadoEm        DateTime            @default(now())               @map("criado_em")

  certificado      CertificadoDigital @relation(fields: [certificadoId], references: [id])

  @@map("procuracoes_eletronicas")
}

model CertificadoLog {
  id            BigInt             @id @default(autoincrement())
  certificadoId String             @map("certificado_id")
  tenantId      String             @map("tenant_id")
  usuarioId     String?            @map("usuario_id")
  usuarioNome   String?            @map("usuario_nome")
  acao          CertificadoAcao
  descricao     String?
  ipOrigem      String?            @map("ip_origem")
  criadoEm      DateTime           @default(now()) @map("criado_em")

  certificado   CertificadoDigital @relation(fields: [certificadoId], references: [id])

  @@index([certificadoId])
  @@index([tenantId, criadoEm])
  @@map("certificados_logs")
}

// ── Distribuição de DF-e (NF-e / CT-e / NFS-e) ───────────────────────────────

enum DfeLoteStatus {
  RECEBIDO
  PROCESSANDO
  PROCESSADO
  ERRO
  REPROCESSAR
}

enum DfeTipoDocumento {
  PROC_NFE
  PROC_EVENTO_NFE
  RES_NFE
  RES_EVENTO
}

/// Configuração de monitoramento DF-e por CNPJ/tenant
model DfeConfig {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  /// CNPJ monitorado, 14 dígitos sem máscara
  cnpj          String
  /// Código IBGE da UF (ex: 35 = SP, 41 = PR, 43 = RS)
  cUf           Int      @map("c_uf")
  /// 1 = produção, 2 = homologação
  tpAmb         Int      @default(1) @map("tp_amb")
  certificadoId String   @map("certificado_id")
  ativo         Boolean  @default(true)
  /// Horário de captura no formato "HH:MM" (ex: "08:00")
  horarioCaptura  String  @default("00:00") @map("horario_captura")
  /// Intervalo em minutos entre execuções (ex: 60 = a cada 1h)
  intervaloMinutos Int   @default(60) @map("intervalo_minutos")
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")
  criadoPorId   String   @map("criado_por_id")

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  certificado CertificadoDigital @relation(fields: [certificadoId], references: [id])
  criadoPor   Usuario            @relation("DfeConfigCriadoPor", fields: [criadoPorId], references: [id])
  controle    DfeNsuControle?
  gaps        DfeGapNsu[]
  varredura   DfeVarreduraNsu?

  @@unique([tenantId, cnpj])
  @@index([tenantId, ativo])
  @@map("dfe_configs")
}

/// Controle de NSU com lock distribuído por CNPJ
model DfeNsuControle {
  id                String    @id @default(uuid())
  configId          String    @unique @map("config_id")
  tenantId          String    @map("tenant_id")
  cnpj              String
  /// Último NSU processado com sucesso (15 dígitos, zero-padded)
  ultimoNsu         String    @default("000000000000000") @map("ultimo_nsu")
  /// maxNSU recebido na última resposta da SEFAZ
  maxNsu            String    @default("000000000000000") @map("max_nsu")
  ultimaConsulta    DateTime? @map("ultima_consulta")
  proximaConsulta   DateTime? @map("proxima_consulta")
  // — lock distribuído —
  emProcessamento   Boolean   @default(false) @map("em_processamento")
  lockId            String?   @map("lock_id")
  lockAte           DateTime? @map("lock_ate")
  /// "hostname:pid" do processo que detém o lock
  lockProcessoId    String?   @map("lock_processo_id")
  // — estatísticas —
  totalDocBaixados  Int       @default(0) @map("total_doc_baixados")
  totalLotes        Int       @default(0) @map("total_lotes")
  totalErros        Int       @default(0) @map("total_erros")
  ultimoErro        String?   @map("ultimo_erro")
  ultimoErroEm      DateTime? @map("ultimo_erro_em")
  errosConsecutivos Int       @default(0) @map("erros_consecutivos")
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")

  config DfeConfig @relation(fields: [configId], references: [id])
  lotes  DfeLote[]

  @@unique([tenantId, cnpj])
  @@index([proximaConsulta, emProcessamento])
  @@map("dfe_nsu_controles")
}

/// Lote de requisição à SEFAZ — cada chamada ao web service gera um lote
model DfeLote {
  id             String        @id @default(uuid())
  controleId     String        @map("controle_id")
  tenantId       String        @map("tenant_id")
  cnpj           String
  /// NSU enviado na requisição
  nsuEnviado     String        @map("nsu_enviado")
  cStat          String        @map("c_stat")
  xMotivo        String        @map("x_motivo")
  ultNsuRecebido String        @map("ult_nsu_recebido")
  maxNsuRecebido String        @map("max_nsu_recebido")
  qtdDocumentos  Int           @default(0) @map("qtd_documentos")
  status         DfeLoteStatus @default(RECEBIDO)
  tentativas     Int           @default(1)
  duracaoMs      Int?          @map("duracao_ms")
  iniciadoEm     DateTime      @default(now()) @map("iniciado_em")
  finalizadoEm   DateTime?     @map("finalizado_em")
  erroMensagem   String?       @map("erro_mensagem")

  controle   DfeNsuControle @relation(fields: [controleId], references: [id])
  documentos DfeDocumento[]

  @@index([tenantId, cnpj, status])
  @@index([tenantId, iniciadoEm])
  @@index([controleId, status])
  @@map("dfe_lotes")
}

/// Documento fiscal eletrônico baixado da SEFAZ
model DfeDocumento {
  id               String           @id @default(uuid())
  loteId           String           @map("lote_id")
  tenantId         String           @map("tenant_id")
  cnpjDestinatario String           @map("cnpj_destinatario")
  /// NSU do documento (15 dígitos, zero-padded) — chave natural
  nsu              String
  /// Schema XML conforme SEFAZ (ex: "procNFe_v4.00.xsd")
  schema           String
  tipoDocumento    DfeTipoDocumento @map("tipo_documento")
  /// XML original descomprimido — null quando armazenado no GCS (ver xmlStoragePath)
  xmlOriginal      Bytes?           @map("xml_original")
  /// Path do XML no Google Cloud Storage (ex: xmls/{tenantId}/{cnpj}/{nsu}.xml)
  xmlStoragePath   String?          @map("xml_storage_path") @db.VarChar(500)
  /// SHA-256 do XML para validação de integridade
  xmlHash          String           @map("xml_hash")
  chaveAcesso      String?          @map("chave_acesso")
  nfeEmitenteCnpj  String?          @map("nfe_emitente_cnpj")
  nfeEmitenteNome  String?          @map("nfe_emitente_nome")
  nfeValorTotal    Decimal?         @map("nfe_valor_total") @db.Decimal(15, 2)
  nfeDhEmissao     DateTime?        @map("nfe_dh_emissao")
  nfeSituacao           String?          @map("nfe_situacao")
  eventoTipo            String?          @map("evento_tipo")
  eventoDescricao       String?          @map("evento_descricao")
  nfeTransportadorCnpj  String?          @map("nfe_transportador_cnpj")
  nfeAutXmlCnpjs        String?          @map("nfe_autxml_cnpjs")
  nfeDestinatarioCnpj   String?          @map("nfe_destinatario_cnpj")
  processado       Boolean          @default(false)
  processadoEm     DateTime?        @map("processado_em")
  erroProcessamento String?         @map("erro_processamento")
  criadoEm         DateTime         @default(now()) @map("criado_em")

  lote              DfeLote                @relation(fields: [loteId], references: [id])
  manifestacoes     DfeManifestacao[]
  gapsRecuperados   DfeGapNsu[]
  etiquetas         DfeDocumentoEtiqueta[]
  etiquetaHistorico EtiquetaHistorico[]

  /// Idempotência: mesmo NSU nunca é inserido duas vezes por tenant
  @@unique([tenantId, nsu])
  @@index([tenantId, cnpjDestinatario])
  @@index([tenantId, nfeDestinatarioCnpj])
  @@index([tenantId, chaveAcesso])
  @@index([tenantId, tipoDocumento])
  @@index([tenantId, processado])
  @@index([tenantId, nfeDhEmissao])
  @@map("dfe_documentos")
}

/// Trilha de auditoria de todas as operações NSU/DF-e
model DfeAuditoria {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  cnpj      String
  operacao  String
  nsuAntes  String?  @map("nsu_antes")
  nsuDepois String?  @map("nsu_depois")
  cStat     String?  @map("c_stat")
  sucesso   Boolean
  detalhe   String?  @db.Text
  duracaoMs Int?     @map("duracao_ms")
  hostname  String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@index([tenantId, cnpj, criadoEm])
  @@index([tenantId, sucesso])
  @@map("dfe_auditorias")
}

// ── Controle de lacunas NSU (gaps) ────────────────────────────────────────────

enum DfeGapStatus {
  /// Gap detectado, aguarda tentativa de recuperação via consNSU
  PENDENTE
  /// SEFAZ retornou cStat=138 — documento recuperado com sucesso
  RECUPERADO
  /// SEFAZ retornou cStat=137 — NSU não existe no Ambiente Nacional
  INEXISTENTE
  /// Máximo de tentativas atingido sem resposta definitiva
  ESGOTADO
}

/// Lacuna NSU detectada entre documentos consecutivos de um lote.
/// Recuperada pontualmente via consNSU conforme MOC 7.0 seção 5.7.4.5.
model DfeGapNsu {
  id              String       @id @default(uuid())
  tenantId        String       @map("tenant_id")
  cnpj            String
  configId        String       @map("config_id")
  /// NSU identificado como faltante (15 dígitos zero-padded)
  nsuFaltante     String       @map("nsu_faltante")
  status          DfeGapStatus @default(PENDENTE)
  tentativas      Int          @default(0)
  /// NSU do documento anterior que gerou a detecção do gap
  nsuAnterior     String       @map("nsu_anterior")
  /// NSU do documento posterior que confirmou o gap
  nsuPosterior    String       @map("nsu_posterior")
  proximaTentativa DateTime?   @map("proxima_tentativa")
  recuperadoEm    DateTime?    @map("recuperado_em")
  /// ID do DfeDocumento inserido após recuperação bem-sucedida
  documentoId     String?      @map("documento_id")
  erroMensagem    String?      @map("erro_mensagem") @db.Text
  criadoEm        DateTime     @default(now()) @map("criado_em")
  atualizadoEm    DateTime     @updatedAt @map("atualizado_em")

  config    DfeConfig     @relation(fields: [configId], references: [id])
  documento DfeDocumento? @relation(fields: [documentoId], references: [id])

  /// Garante que o mesmo NSU faltante não seja registrado duas vezes por tenant
  @@unique([tenantId, nsuFaltante])
  @@index([tenantId, cnpj, status])
  @@index([status, proximaTentativa])
  @@index([configId, status])
  @@map("dfe_gap_nsus")
}

// ── Varredura retroativa de NSU ───────────────────────────────────────────────

enum DfeVarreduraStatus {
  /// Varredura em execução pelo job
  ATIVA
  /// Varredura pausada pelo usuário ou aguardando retomada
  PAUSADA
  /// Varredura concluída (alcançou nsuFim)
  CONCLUIDA
  /// Varredura encerrada por erro não-recuperável
  ERRO
}

/// Varredura retroativa: itera NSUs via consNSU para recuperar documentos
/// não enfileirados na distribuição normal (anteriores ao primeiro distNSU).
model DfeVarreduraNsu {
  id               String             @id @default(uuid())
  /// Um único registro por configuração (upsert ao iniciar nova varredura)
  configId         String             @unique @map("config_id")
  tenantId         String             @map("tenant_id")
  cnpj             String
  status           DfeVarreduraStatus @default(PAUSADA)
  /// NSU inicial da varredura (15 dígitos, zero-padded)
  nsuInicio        String             @map("nsu_inicio")
  /// NSU final da varredura (15 dígitos) — geralmente maxNSU no momento do início
  nsuFim           String             @map("nsu_fim")
  /// NSU atual sendo processado — atualizado a cada lote
  nsuAtual         String             @map("nsu_atual")
  /// Quantidade de NSUs já consultados
  totalConsultado  Int                @default(0) @map("total_consultado")
  /// Quantidade de documentos recuperados (cStat=138)
  totalRecuperado  Int                @default(0) @map("total_recuperado")
  iniciadoEm       DateTime?          @map("iniciado_em")
  pausadoEm        DateTime?          @map("pausado_em")
  concluidoEm      DateTime?          @map("concluido_em")
  ultimoErro       String?            @map("ultimo_erro") @db.Text
  criadoEm         DateTime           @default(now()) @map("criado_em")
  atualizadoEm     DateTime           @updatedAt @map("atualizado_em")

  config DfeConfig @relation(fields: [configId], references: [id])

  @@index([tenantId, status])
  @@map("dfe_varreduras_nsu")
}

// ── Etiquetas ─────────────────────────────────────────────────────────────────

/// Etiqueta de classificação aplicável a documentos fiscais (DfeDocumento).
/// Uniqueness de nome e cor é validada em nível de serviço (ativas por tenant),
/// pois o soft-delete (deletadoEm) impede o uso de unique constraints no banco.
model Etiqueta {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  nome         String    @db.VarChar(100)
  cor          String    @db.VarChar(7)
  /// Apenas uma etiqueta por tenant pode ter padrao=true (troca atômica no serviço)
  padrao       Boolean   @default(false)
  /// Soft delete — registros com deletadoEm != null são ignorados nas consultas
  deletadoEm   DateTime? @map("deletado_em")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  tenant     Tenant                 @relation(fields: [tenantId], references: [id])
  documentos DfeDocumentoEtiqueta[]

  @@index([tenantId, deletadoEm])
  @@map("etiquetas")
}

/// Tabela de junção entre DfeDocumento e Etiqueta.
model DfeDocumentoEtiqueta {
  id          String   @id @default(uuid())
  documentoId String   @map("documento_id")
  etiquetaId  String   @map("etiqueta_id")
  criadoEm    DateTime @default(now()) @map("criado_em")

  documento DfeDocumento @relation(fields: [documentoId], references: [id])
  etiqueta  Etiqueta     @relation(fields: [etiquetaId], references: [id])

  @@unique([documentoId, etiquetaId])
  @@index([etiquetaId])
  @@map("dfe_documento_etiquetas")
}

/// Histórico imutável de alterações de etiquetas em documentos fiscais.
/// Gerado automaticamente em toda operação de associação/desassociação (individual ou em massa).
/// Sem updatedAt — imutável por design.
model EtiquetaHistorico {
  id              String   @id @default(uuid())
  documentoId     String   @map("documento_id")
  usuarioId       String?  @map("usuario_id")
  /// Snapshot das etiquetas antes da alteração (array de {id, nome, cor})
  etiquetasAntes  Json     @map("etiquetas_antes")
  /// Snapshot das etiquetas depois da alteração (array de {id, nome, cor})
  etiquetasDepois Json     @map("etiquetas_depois")
  criadoEm        DateTime @default(now()) @map("criado_em")

  documento DfeDocumento @relation(fields: [documentoId], references: [id])
  usuario   Usuario?     @relation(fields: [usuarioId], references: [id])

  @@index([documentoId, criadoEm])
  @@map("etiqueta_historico")
}

// ── Manifestação do Destinatário ──────────────────────────────────────────────

enum DfeManifestacaoStatus {
  /// Aguarda envio à SEFAZ
  PENDENTE
  /// Enviado com sucesso (cStat=135)
  ENVIADO
  /// Rejeitado pela SEFAZ (cStat de rejeição)
  REJEITADO
  /// Falha técnica (rede, timeout) — será retentado
  ERRO
}

/// Evento de manifestação do destinatário enviado ao WS NFeRecepcaoEvento.
/// Cobre os quatro tipos oficiais do MOC 7.0 seção 5.11:
///   210200 – Ciência da Operação
///   210210 – Confirmação da Operação
///   210220 – Operação não Realizada
///   210240 – Desconhecimento da Operação
model DfeManifestacao {
  id           String                 @id @default(uuid())
  tenantId     String                 @map("tenant_id")
  cnpj         String
  documentoId  String                 @map("documento_id")
  chaveAcesso  String                 @map("chave_acesso") @db.VarChar(44)
  /// Código do evento conforme MOC (ex: "210200")
  tpEvento     String                 @map("tp_evento") @db.VarChar(6)
  /// Descrição textual conforme MOC (ex: "Ciência da Operação")
  xEvento      String                 @map("x_evento") @db.VarChar(60)
  /// Sequencial do evento para o mesmo tipo (1 ou 2)
  nSeqEvento   Int                    @default(1) @map("n_seq_evento")
  /// Justificativa — obrigatória para tpEvento=210220, mínimo 15 chars
  xJust        String?                @map("x_just") @db.VarChar(255)
  status       DfeManifestacaoStatus  @default(PENDENTE)
  tentativas   Int                    @default(0)
  /// Número de protocolo retornado pela SEFAZ após sucesso
  nProt        String?                @map("n_prot") @db.VarChar(15)
  cStat        String?                @map("c_stat") @db.VarChar(3)
  xMotivo      String?                @map("x_motivo") @db.VarChar(255)
  dhRegEvento  DateTime?              @map("dh_reg_evento")
  /// XML do envelope enviado (armazenado para auditoria e reprocessamento)
  xmlEnvio     Bytes?                 @map("xml_envio")
  /// XML da resposta bruta da SEFAZ
  xmlResposta  Bytes?                 @map("xml_resposta")
  erroMensagem String?                @map("erro_mensagem") @db.Text
  criadoEm     DateTime               @default(now()) @map("criado_em")
  enviadoEm    DateTime?              @map("enviado_em")
  atualizadoEm DateTime               @updatedAt @map("atualizado_em")

  documento DfeDocumento @relation(fields: [documentoId], references: [id])

  /// Um tipo de evento por chave de acesso por tenant é único (nSeqEvento controla reenvios)
  @@unique([tenantId, chaveAcesso, tpEvento, nSeqEvento])
  @@index([tenantId, cnpj, status])
  @@index([tenantId, chaveAcesso])
  @@index([status, criadoEm])
  @@index([documentoId])
  @@map("dfe_manifestacoes")
}

// ── Exportação de DANFE ───────────────────────────────────────────────────────

enum DfeExportJobStatus {
  PENDENTE
  PROCESSANDO
  CONCLUIDO
  ERRO
}

/// Job de exportação em lote de DANFEs — geração de PDF + ZIP + envio por e-mail
model DfeExportJob {
  id              String             @id @default(uuid())
  tenantId        String             @map("tenant_id")
  usuarioId       String?            @map("usuario_id")
  status          DfeExportJobStatus @default(PENDENTE)
  email           String?
  documentoIds    String             @map("documento_ids") @db.Text
  totalDocs       Int                @default(0) @map("total_docs")
  docsProcessados Int                @default(0) @map("docs_processados")
  arquivoNome     String?            @map("arquivo_nome")
  erroMensagem    String?            @map("erro_mensagem") @db.Text
  criadoEm        DateTime           @default(now()) @map("criado_em")
  atualizadoEm    DateTime           @updatedAt @map("atualizado_em")
  expiradoEm      DateTime?          @map("expirado_em")

  @@index([tenantId, status])
  @@index([tenantId, criadoEm])
  @@map("dfe_export_jobs")
}

// ─── SPED ─────────────────────────────────────────────────────────────────────

enum SpedStatus {
  DISPONIVEL
  ERRO
  INDISPONIVEL
}

model SpedArquivo {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  cnpj          String
  tipo          String      // EFD_ICMS | EFD_CONTRIBUICOES | ECD | ECF
  gcsBucket     String      @map("gcs_bucket")
  gcsPath       String      @map("gcs_path")
  nomeArquivo   String      @map("nome_arquivo")
  dataDocumento DateTime    @map("data_documento")
  status        SpedStatus
  mensagemErro  String?     @map("mensagem_erro") @db.Text
  criadoEm      DateTime    @default(now()) @map("criado_em")
  atualizadoEm  DateTime    @updatedAt @map("atualizado_em")

  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, cnpj, tipo, dataDocumento], name: "tenantId_cnpj_tipo_dataDocumento")
  @@index([tenantId, cnpj])
  @@map("sped_arquivos")
}

// ─── OBRIGAÇÕES ACESSÓRIAS ────────────────────────────────────────────────────
// Enums gerenciados na camada de aplicação (RN-03). Banco armazena varchar.

model ObrigacaoAcessoria {
  id                     String              @id @default(uuid())
  idEvento               String              @unique @map("id_evento") @db.VarChar(255)
  tipoObrigacao          String              @map("tipo_obrigacao") @db.VarChar(30)
  cnpj                   String              @db.VarChar(14)
  inscricaoEstadual      String?             @map("inscricao_estadual") @db.VarChar(20)
  dataInicial            DateTime            @map("data_inicial") @db.Date
  dataFinal              DateTime            @map("data_final") @db.Date
  finalidade             String              @db.VarChar(20)
  hash                   String              @db.VarChar(64)
  dataEntrega            DateTime            @map("data_entrega") @db.Timestamptz(6)
  nomeArquivo            String              @map("nome_arquivo") @db.VarChar(500)
  caminhoBucket          String              @map("caminho_bucket") @db.VarChar(1000)
  statusProcessamento    String              @map("status_processamento") @db.VarChar(50)
  origem                 String              @db.VarChar(20)
  versao                 Int                 @default(1)
  versaoAtual            Boolean             @default(true) @map("versao_atual")
  dataRecebimentoEvento  DateTime            @map("data_recebimento_evento") @db.Timestamptz(6)
  obrigacaoPaiId         String?             @map("obrigacao_pai_id")
  criadoEm               DateTime            @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm           DateTime            @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  atualizadoPor          String              @map("atualizado_por") @db.VarChar(255)

  // RN-11: auto-relacionamento para versões/retificações
  obrigacaoPai           ObrigacaoAcessoria?  @relation("ObrigacaoVersoes", fields: [obrigacaoPaiId], references: [id])
  versoes                ObrigacaoAcessoria[] @relation("ObrigacaoVersoes")

  @@index([cnpj, tipoObrigacao, dataInicial, dataFinal])
  @@index([statusProcessamento])
  @@index([versaoAtual])
  @@map("obrigacao_acessoria")
}
