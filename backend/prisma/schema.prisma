// ── Documentos Regulatórios ───────────────────────────────────────────────────

enum StatusDocReg {
  rascunho
  em_revisao
  aguardando_assinaturas
  vigente
  arquivado
}

enum TipoRevisaoDoc {
  comentario
  ajuste_solicitado
  aprovado
}

enum MetodoAssinatura {
  senha
  icp_brasil
}

model TipoDocumentoReg {
  id                    String                      @id @default(uuid())
  tenantId              String                      @map("tenant_id")
  nome                  String
  descricao             String?
  periodicidadeDias     Int?                        @map("periodicidade_dias")
  alertaAntesDias       Int                         @default(30) @map("alerta_antes_dias")
  ativo                 Boolean                     @default(true)
  exigeRevisao          Boolean                     @default(false) @map("exige_revisao")
  assinaturaSequencial  Boolean                     @default(false) @map("assinatura_sequencial")
  criadoEm              DateTime                    @default(now()) @map("criado_em")
  tenant                Tenant                      @relation(fields: [tenantId], references: [id])
  documentos            DocumentoReg[]
  workflowRevisores     WorkflowRevisorTipoDoc[]
  workflowSignatarios   WorkflowSignatarioTipoDoc[]

  @@unique([tenantId, nome])
  @@map("tipos_documento_reg")
}

model DocumentoReg {
  id           String           @id @default(uuid())
  tenantId     String           @map("tenant_id")
  tipoId       String           @map("tipo_id")
  titulo       String
  versao       String           @default("1.0")
  status       StatusDocReg     @default(rascunho)
  storageKey   String?          @map("storage_key")
  nomeArquivo  String?          @map("nome_arquivo")
  hashArquivo  String?          @map("hash_arquivo")
  dataValidade DateTime?        @map("data_validade")
  criadoEm     DateTime         @default(now()) @map("criado_em")
  atualizadoEm DateTime         @updatedAt @map("atualizado_em")
  criadoPorId  String           @map("criado_por_id")
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  tipo         TipoDocumentoReg @relation(fields: [tipoId], references: [id])
  criadoPor    Usuario          @relation("DocRegCriadoPor", fields: [criadoPorId], references: [id])
  revisoes     RevisaoDocReg[]
  signatarios  SignatarioDocReg[]
  assinaturas  AssinaturaDocReg[]
  revisores    RevisorDocReg[]

  @@index([tenantId, status])
  @@map("documentos_reg")
}

model RevisaoDocReg {
  id          String         @id @default(uuid())
  documentoId String         @map("documento_id")
  tipo        TipoRevisaoDoc @default(comentario)
  texto       String
  criadoEm    DateTime       @default(now()) @map("criado_em")
  criadoPorId String         @map("criado_por_id")
  documento   DocumentoReg   @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  criadoPor   Usuario        @relation(fields: [criadoPorId], references: [id])

  @@map("revisoes_doc_reg")
}

model SignatarioDocReg {
  id          String       @id @default(uuid())
  documentoId String       @map("documento_id")
  usuarioId   String       @map("usuario_id")
  ordem       Int?
  obrigatorio Boolean      @default(true)
  documento   DocumentoReg @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  usuario     Usuario      @relation(fields: [usuarioId], references: [id])

  @@unique([documentoId, usuarioId])
  @@map("signatarios_doc_reg")
}

model AssinaturaDocReg {
  id            String           @id @default(uuid())
  documentoId   String           @map("documento_id")
  usuarioId     String           @map("usuario_id")
  assinadoEm    DateTime         @default(now()) @map("assinado_em")
  metodo        MetodoAssinatura @default(senha)
  hashDocumento String           @map("hash_documento")
  ip            String?
  certificadoCN String?          @map("certificado_cn")
  documento     DocumentoReg     @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  usuario       Usuario          @relation(fields: [usuarioId], references: [id])

  @@unique([documentoId, usuarioId])
  @@map("assinaturas_doc_reg")
}

model RevisorDocReg {
