  empresaId    String    @unique @map("empresa_id")
  cnpj         String    @db.VarChar(14)
  optante      Boolean   // true = empresa é optante do Simples Nacional
  // ATIVO | EXCLUIDO | SUSPENSO | MEI | NAO_OPTANTE
  situacao     String    @db.VarChar(20)
  dataOpcao    DateTime? @map("data_opcao")    @db.Date
  dataExclusao DateTime? @map("data_exclusao") @db.Date
  consultadoEm DateTime  @default(now()) @map("consultado_em")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  empresa Empresa @relation(fields: [empresaId], references: [id])

