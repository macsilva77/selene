generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String                   @id @default(uuid())
  nome               String
  slug               String                   @unique
  cnpj               String?                  @unique
  plano              PlanoTenant              @default(free)
  ativo              Boolean                  @default(true)
  criadoEm           DateTime                 @default(now()) @map("criado_em")
  atualizadoEm       DateTime                 @updatedAt @map("atualizado_em")
  nomeFantasia        String?                  @map("nome_fantasia")
  email               String?
  telefone            String?
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  municipio           String?
  uf                  String?
  cnaePrincipal       String?                  @map("cnae_principal")
  inscricaoEstadual   String?                  @map("inscricao_estadual")
  inscricaoMunicipal  String?                  @map("inscricao_municipal")
  regimeTributario    String?                  @map("regime_tributario")
  situacaoCadastral   String?                  @map("situacao_cadastral")
  tipoEstabelecimento String?                  @map("tipo_estabelecimento")
  auditLogs           AuditLog[]
  certificados        CertificadoDigital[]
  boardColunas       BoardColuna[]
  configsNotificacao ConfigNotificacao[]
  contratos          Contrato[]
  documentos         Documento[]
  empresas           Empresa[]
  fornecedores       Fornecedor[]
  iniciativas        Iniciativa[]
  notificacoes       Notificacao[]
  pendencias         Pendencia[]
  perfis             Perfil[]
  tiposOrigem        TipoOrigem[]
  unidades             UnidadeOrganizacional[]
  unidadeVisibilidades UnidadeVisibilidade[]
  usuarios             Usuario[]
  tiposDocumentoReg    TipoDocumentoReg[]
  documentosReg        DocumentoReg[]
  dfeConfigs           DfeConfig[]
  cteConfigs           CteConfig[]
  etiquetas            Etiqueta[]
  spedArquivos         SpedArquivo[]
  creditoEmpresas      CreditoEmpresa[]
  cfCompetencias       ClientesFornecedoresCompetencia[]
  ecfIndicadores          EcfIndicador[]
  faturamentoCompetencias FaturamentoCompetencia[]
  snSituacoes             SimplesNacionalSituacao[]
  pgdasDeclaracoes        PgdasDeclaracao[]
  certificadoConvites     CertificadoConvite[]

  @@map("tenants")
}

model Usuario {
  id                     String                  @id @default(uuid())
  nome                   String
  email                  String                  @map("email")
  senhaHash              String?                 @map("senha_hash")
  role                   Role
  ativo                  Boolean                 @default(true)
  criadoEm               DateTime                @default(now()) @map("criado_em")
  atualizadoEm           DateTime                @updatedAt @map("atualizado_em")
  tenantId               String                  @map("tenant_id")
  resetToken             String?                 @map("reset_token")
  resetTokenExpiry       DateTime?               @map("reset_token_expiry")
  senhaAlteradaEm        DateTime?               @map("senha_alterada_em")
  cpf                    String?
  telefone               String?
  cep                    String?
  logradouro             String?
  numero                 String?
  complemento            String?
  bairro                 String?
  municipio              String?
  uf                     String?
  atualizacoesIniciativa  AtualizacaoIniciativa[]
  boardColunasCriadas     BoardColuna[]            @relation("BoardColunasCriadas")
  calendarioIntegracoes   CalendarioIntegracao[]
  contratosCriados        Contrato[]               @relation("ContratoCriadoPor")
  contratosGestor         Contrato[]               @relation("ContratoGestor")
  contratosResponsavel    Contrato[]               @relation("ContratoResponsavel")
  documentos              Documento[]
  iniciativasCriadas      Iniciativa[]             @relation("IniciativaCriadaPor")
  iniciativasResponsavel  Iniciativa[]             @relation("IniciativaResponsavel")
  movimentacoes           MovimentacaoPendencia[]
  notificacoes            Notificacao[]
  pendenciasAuditor       Pendencia[]              @relation("PendenciaAuditor")
  pendenciasDestinatario  Pendencia[]              @relation("PendenciaDestinatario")
  pendenciasResponsavel   Pendencia[]              @relation("PendenciaResponsavel")
  perfis                  UsuarioPerfil[]
  unidades                UsuarioUnidade[]
  unidadesResponsavel     UnidadeOrganizacional[]  @relation("UnidadeResponsavel")
  visibilidadesCriadas    UnidadeVisibilidade[]    @relation("VisibilidadeCriadaPor")
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  documentosRegCriados    DocumentoReg[]           @relation("DocRegCriadoPor")
  revisoesDocReg          RevisaoDocReg[]
  signatariosDocReg           SignatarioDocReg[]
  assinaturasDocReg           AssinaturaDocReg[]
  revisoresDocReg             RevisorDocReg[]
  workflowRevisoresTipoDoc    WorkflowRevisorTipoDoc[]
  workflowSignatariosTipoDoc  WorkflowSignatarioTipoDoc[]
  certificadosCriados         CertificadoDigital[]        @relation("CertCriadoPor")
  certificadoConvitesCriados  CertificadoConvite[]        @relation("ConviteCertCriadoPor")
  dfeConfigsCriados           DfeConfig[]                 @relation("DfeConfigCriadoPor")
  cteConfigsCriados           CteConfig[]                 @relation("CteConfigCriadoPor")
  cteEtiquetaHistorico        CteEtiquetaHistorico[]
  etiquetaHistorico           EtiquetaHistorico[]
  nfseEtiquetaHistorico       NfseEtiquetaHistorico[]

  @@unique([tenantId, email])
  @@map("usuarios")
}

model CalendarioIntegracao {
  id        String         @id @default(uuid())
  usuarioId String         @map("usuario_id")
  tipo      CalendarioTipo
  email     String
  ativo     Boolean        @default(true)
  criadoEm  DateTime       @default(now()) @map("criado_em")
  usuario   Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("calendario_integracoes")
}

model Empresa {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  nome                String
  nomeFantasia        String?  @map("nome_fantasia")
  cnpj                String
  email               String?
  telefone            String?
  cep                 String?  @db.VarChar(10)
  logradouro          String?
  numero              String?  @db.VarChar(20)
  complemento         String?
  bairro              String?
  municipio           String?
  uf                  String?  @db.VarChar(2)
  cnaePrincipal       String?  @map("cnae_principal")
  cnaeSecundario      String?  @map("cnae_secundario")
  quadroSocietario    String?  @map("quadro_societario")
  inscricaoEstadual   String?  @map("inscricao_estadual")
  inscricaoMunicipal  String?  @map("inscricao_municipal")
  regimeTributario    String?  @map("regime_tributario")
  situacaoCadastral   String?  @map("situacao_cadastral")
  tipoEstabelecimento String?  @map("tipo_estabelecimento")
  naturezaJuridica    String?  @map("natureza_juridica")
  dataInicioAtividade String?  @map("data_inicio_atividade")
  ativo               Boolean  @default(true)
  criadoEm            DateTime @default(now()) @map("criado_em")
  atualizadoEm        DateTime @updatedAt @map("atualizado_em")
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  certificados        CertificadoEmpresa[]
  snSituacao          SimplesNacionalSituacao?
  pgdasDeclaracoes    PgdasDeclaracao[]

  @@unique([tenantId, cnpj])
  @@map("empresas")
}

model Fornecedor {
  id                  String     @id @default(uuid())
  nome                String
  cnpj                String
  email               String?
  telefone            String?
  ativo               Boolean    @default(true)
  criadoEm            DateTime   @default(now()) @map("criado_em")
  atualizadoEm        DateTime   @updatedAt @map("atualizado_em")
  tenantId            String     @map("tenant_id")
  nomeFantasia        String?    @map("nome_fantasia")
  cep                 String?    @db.VarChar(10)
  logradouro          String?
  numero              String?    @db.VarChar(20)
  complemento         String?
  bairro              String?
  municipio           String?
  uf                  String?    @db.VarChar(2)
  cnaePrincipal       String?    @map("cnae_principal")
  inscricaoEstadual   String?    @map("inscricao_estadual")
  inscricaoMunicipal  String?    @map("inscricao_municipal")
  regimeTributario    String?    @map("regime_tributario")
  situacaoCadastral   String?    @map("situacao_cadastral")
  tipoEstabelecimento String?    @map("tipo_estabelecimento")
  contratos           Contrato[]
  tenant              Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, cnpj])
  @@map("fornecedores")
}

model Contrato {
  id               String               @id @default(uuid())
  numero           String
  objeto           String
  modalidade       ContratoModalidade
  valor            Decimal              @db.Decimal(15, 2)
  dataInicio       DateTime             @map("data_inicio") @db.Date
  dataTermino      DateTime             @map("data_termino") @db.Date
  renovavel        Boolean              @default(false)
  maxRenovacoes    Int?                 @map("max_renovacoes")
  renovacoesFeiras Int                  @default(0) @map("renovacoes_feitas")
  status           ContratoStatus       @default(vigente)
  observacoes      String?
  tags             String[]
  version          Int                  @default(1)
  criadoEm         DateTime             @default(now()) @map("criado_em")
  atualizadoEm     DateTime             @updatedAt @map("atualizado_em")
  fornecedorId     String               @map("fornecedor_id")
  responsavelId    String               @map("responsavel_id")
  criadoPorId      String               @map("criado_por")
  tenantId         String               @map("tenant_id")
  numeroProcesso   String?              @map("numero_processo") @db.VarChar(100)
  termoAditivo     String?              @map("termo_aditivo") @db.VarChar(100)
  valorParcela     Decimal?             @map("valor_parcela") @db.Decimal(15, 2)
  dataAssinatura   DateTime?            @map("data_assinatura") @db.Date
  dataPublicacao   DateTime?            @map("data_publicacao") @db.Date
  prazo            String?              @db.VarChar(100)
  fiscalNome       String?              @map("fiscal_nome") @db.VarChar(255)
  oficioTceal      String?              @map("oficio_tceal") @db.VarChar(150)
  protocoloTceal   String?              @map("protocolo_tceal") @db.VarChar(100)
  gestorId         String?              @map("gestor_id")
  unidadeId        String?              @map("unidade_id")
  subtipo          ContratoSubtipo?
  aditivos         Aditivo[]
  criadoPor        Usuario              @relation("ContratoCriadoPor", fields: [criadoPorId], references: [id])
  fornecedor       Fornecedor           @relation(fields: [fornecedorId], references: [id])
  gestor           Usuario?             @relation("ContratoGestor", fields: [gestorId], references: [id])
  responsavel      Usuario              @relation("ContratoResponsavel", fields: [responsavelId], references: [id])
  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  unidade          UnidadeOrganizacional? @relation(fields: [unidadeId], references: [id])
  documentos       Documento[]          @relation("ContratoDocumentos")
  iniciativas      IniciativaContrato[]
  pendencias       Pendencia[]
  termosAditivos   TermoAditivo[]

  @@unique([tenantId, numero])
  @@index([tenantId, status])
  @@index([tenantId, dataTermino])
  @@index([tenantId, responsavelId])
  @@map("contratos")
}

model Aditivo {
  id           String   @id @default(uuid())
  contratoId   String   @map("contrato_id")
  prazAnterior DateTime @map("prazo_anterior") @db.Date
  novoPrazo    DateTime @map("novo_prazo") @db.Date
  motivo       String
  criadoPorId  String   @map("criado_por")
  criadoEm     DateTime @default(now()) @map("criado_em")
  contrato     Contrato @relation(fields: [contratoId], references: [id])

  @@map("aditivos")
}

model TermoAditivo {
  id                 String      @id @default(uuid())
  contratoId         String      @map("contrato_id")
  numero             String      @db.VarChar(100)
  tipo               TipoAditivo
  dataAssinatura     DateTime    @map("data_assinatura") @db.Date
  dataPublicacao     DateTime?   @map("data_publicacao") @db.Date
  vigenciaAnterior   DateTime?   @map("vigencia_anterior") @db.Date
  novaVigencia       DateTime?   @map("nova_vigencia") @db.Date
  valorAnterior      Decimal?    @map("valor_anterior") @db.Decimal(15, 2)
  novoValor          Decimal?    @map("novo_valor") @db.Decimal(15, 2)
  percentualReajuste Decimal?    @map("percentual_reajuste") @db.Decimal(5, 2)
  objetoAditivo      String?     @map("objeto_aditivo")
  justificativa      String
  fundamentoLegal    String?     @map("fundamento_legal") @db.VarChar(500)
  publicacaoLink     String?     @map("publicacao_link") @db.VarChar(500)
  criadoPorId        String      @map("criado_por")
  criadoEm           DateTime    @default(now()) @map("criado_em")
  atualizadoEm       DateTime    @updatedAt @map("atualizado_em")
  contrato           Contrato    @relation(fields: [contratoId], references: [id])

  @@map("termos_aditivos")
}

model TipoOrigem {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  nome        String       @db.VarChar(100)
  ativo       Boolean      @default(true)
  criadoEm    DateTime     @default(now()) @map("criado_em")
  iniciativas Iniciativa[]
  pendencias  Pendencia[]
  tenant      Tenant       @relation(fields: [tenantId], references: [id])

  @@map("tipos_origem")
}

model BoardColuna {
  id           String       @id @default(uuid())
  tenantId     String       @map("tenant_id")
  nome         String       @db.VarChar(100)
  ordem        Int
  cor          String?      @db.VarChar(7)
  padrao       Boolean      @default(false)
  ativo        Boolean      @default(true)
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")
  criadoPorId  String?      @map("criado_por")
  criadoPor    Usuario?     @relation("BoardColunasCriadas", fields: [criadoPorId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  iniciativas  Iniciativa[]
  pendencias   Pendencia[]

  @@unique([tenantId, ordem])
  @@map("board_colunas")
}

model Pendencia {
  id              String                  @id @default(uuid())
  titulo          String                  @db.VarChar(200)
  descricao       String
  refExterna      String?                 @map("ref_externa") @db.VarChar(100)
  prazoResposta   DateTime                @map("prazo_resposta") @db.Date
  status          PendenciaStatus         @default(aguardando_resposta)
  prioridade      PrioridadePendencia     @default(media)
  motivoDevolucao     String?                 @map("motivo_devolucao")
  categoriaDevolucao  CategoriaDevolucao?     @map("categoria_devolucao")
  criadoEm        DateTime                @default(now()) @map("criado_em")
  atualizadoEm    DateTime                @updatedAt @map("atualizado_em")
  responsavelId   String                  @map("responsavel_id")
  auditorId       String                  @map("auditor_id")
  contratoId      String?                 @map("contrato_id")
  iniciativaId    String?                 @map("iniciativa_id")
  tenantId        String                  @map("tenant_id")
  destinatarioId  String                  @map("destinatario_id")
  tipoOrigemId    String?                 @map("tipo_origem_id")
  boardColunaId   String?                 @map("board_coluna_id")
  dataInicio      DateTime?               @map("data_inicio") @db.Date
  unidadeId       String?                 @map("unidade_id")
  documentos      Documento[]             @relation("PendenciaDocumentos")
  movimentacoes   MovimentacaoPendencia[]
  auditor         Usuario                 @relation("PendenciaAuditor", fields: [auditorId], references: [id])
  boardColuna     BoardColuna?            @relation(fields: [boardColunaId], references: [id])
  contrato        Contrato?               @relation(fields: [contratoId], references: [id])
  destinatario    Usuario                 @relation("PendenciaDestinatario", fields: [destinatarioId], references: [id])
  iniciativa      Iniciativa?             @relation(fields: [iniciativaId], references: [id])
  responsavel     Usuario                 @relation("PendenciaResponsavel", fields: [responsavelId], references: [id])
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  tipoOrigem      TipoOrigem?             @relation(fields: [tipoOrigemId], references: [id])
  unidade         UnidadeOrganizacional?  @relation(fields: [unidadeId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, prazoResposta])
  @@map("pendencias")
}

model MovimentacaoPendencia {
  id             String           @id @default(uuid())
  pendenciaId    String           @map("pendencia_id")
  usuarioId      String           @map("usuario_id")
  tipo           MovimentacaoTipo
  texto          String
  statusAnterior PendenciaStatus? @map("status_anterior")
  statusNovo     PendenciaStatus? @map("status_novo")
  criadoEm       DateTime         @default(now()) @map("criado_em")
  documentos     Documento[]      @relation("MovimentacaoDocumentos")
  pendencia      Pendencia        @relation(fields: [pendenciaId], references: [id])
  usuario        Usuario          @relation(fields: [usuarioId], references: [id])

  @@map("movimentacoes_pendencia")
}

model Iniciativa {
  id            String                  @id @default(uuid())
  titulo        String
  descricao     String
  categoria     IniciativaCategoria
  prioridade    IniciativaPrioridade
  status        IniciativaStatus        @default(planejada)
  dataInicio    DateTime                @map("data_inicio") @db.Date
  dataLimite    DateTime                @map("data_limite") @db.Date
  criadoEm      DateTime                @default(now()) @map("criado_em")
  atualizadoEm  DateTime                @updatedAt @map("atualizado_em")
  responsavelId String                  @map("responsavel_id")
  criadoPorId   String                  @map("criado_por")
  paiId         String?                 @map("pai_id")
  tenantId      String                  @map("tenant_id")
  progresso     Int                     @default(0)
  tipoOrigemId  String?                 @map("tipo_origem_id")
  boardColunaId String?                 @map("board_coluna_id")
  unidadeId     String?                 @map("unidade_id")
  atualizacoes  AtualizacaoIniciativa[]
  documentos    Documento[]             @relation("IniciativaDocumentos")
  boardColuna   BoardColuna?            @relation(fields: [boardColunaId], references: [id])
  criadoPor     Usuario                 @relation("IniciativaCriadaPor", fields: [criadoPorId], references: [id])
  pai           Iniciativa?             @relation("SubIniciativas", fields: [paiId], references: [id])
  filhos        Iniciativa[]            @relation("SubIniciativas")
  responsavel   Usuario                 @relation("IniciativaResponsavel", fields: [responsavelId], references: [id])
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  tipoOrigem    TipoOrigem?             @relation(fields: [tipoOrigemId], references: [id])
  unidade       UnidadeOrganizacional?  @relation(fields: [unidadeId], references: [id])
  contratos     IniciativaContrato[]
  marcos        Marco[]
  pendencias    Pendencia[]

  @@map("iniciativas")
}

model AtualizacaoIniciativa {
  id           String     @id @default(uuid())
  iniciativaId String     @map("iniciativa_id")
  usuarioId    String     @map("usuario_id")
  texto        String
  avancoAntes  Int        @map("avanco_antes")
  avancoDepois Int        @map("avanco_depois")
  criadoEm     DateTime   @default(now()) @map("criado_em")
  iniciativa   Iniciativa @relation(fields: [iniciativaId], references: [id])
  usuario      Usuario    @relation(fields: [usuarioId], references: [id])

  @@map("atualizacoes_iniciativa")
}

model IniciativaContrato {
  iniciativaId String     @map("iniciativa_id")
  contratoId   String     @map("contrato_id")
  contrato     Contrato   @relation(fields: [contratoId], references: [id])
  iniciativa   Iniciativa @relation(fields: [iniciativaId], references: [id])

  @@id([iniciativaId, contratoId])
  @@map("iniciativas_contratos")
}

model Marco {
  id                 String     @id @default(uuid())
  iniciativaId       String     @map("iniciativa_id")
  titulo             String
  dataAlvo           DateTime   @map("data_alvo") @db.Date
  criteriosConclusao String     @map("criterios_conclusao")
  concluido          Boolean    @default(false)
  concluidoEm        DateTime?  @map("concluido_em")
  criadoEm           DateTime   @default(now()) @map("criado_em")
  iniciativa         Iniciativa @relation(fields: [iniciativaId], references: [id])

  @@map("marcos")
}

model Documento {
  id               String                 @id @default(uuid())
  nomeOriginal     String                 @map("nome_original") @db.VarChar(255)
  storageKey       String                 @unique @map("storage_key")
  mimeType         String                 @map("mime_type") @db.VarChar(100)
  tamanhoBytes     BigInt                 @map("tamanho_bytes")
  entidadeTipo     DocumentoEntidadeTipo  @map("entidade_tipo")
  entidadeId       String                 @map("entidade_id")
  ativo            Boolean                @default(true)
  motivoInativacao String?                @map("motivo_inativacao")
  criadoEm         DateTime               @default(now()) @map("criado_em")
  enviadoPorId     String                 @map("enviado_por")
  tenantId         String                 @map("tenant_id")
  nomeExibicao     String?                @map("nome_exibicao") @db.VarChar(255)
  contratoId       String?                @map("contrato_id")
  pendenciaId      String?                @map("pendencia_id")
  iniciativaId     String?                @map("iniciativa_id")
  movimentacaoId   String?                @map("movimentacao_id")
  contrato         Contrato?              @relation("ContratoDocumentos", fields: [contratoId], references: [id])
  enviadoPor       Usuario                @relation(fields: [enviadoPorId], references: [id])
  iniciativa       Iniciativa?            @relation("IniciativaDocumentos", fields: [iniciativaId], references: [id])
  movimentacao     MovimentacaoPendencia? @relation("MovimentacaoDocumentos", fields: [movimentacaoId], references: [id])
  pendencia        Pendencia?             @relation("PendenciaDocumentos", fields: [pendenciaId], references: [id])
  tenant           Tenant                 @relation(fields: [tenantId], references: [id])

  @@map("documentos")
}

model AuditLog {
  id            BigInt    @id @default(autoincrement())
  correlationId String?   @map("correlation_id") @db.Uuid
  usuarioId     String?   @map("usuario_id")
  entidadeTipo  String    @map("entidade_tipo") @db.VarChar(50)
  entidadeId    String    @map("entidade_id")
  acao          AuditAcao
  payloadAntes  Json?     @map("payload_antes")
  payloadDepois Json?     @map("payload_depois")
  ipOrigem      String?   @map("ip_origem")
  userAgent     String?   @map("user_agent")
  criadoEm      DateTime  @default(now()) @map("criado_em")
  tenantId      String?   @map("tenant_id")
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([criadoEm])
  @@index([entidadeTipo, entidadeId])
  @@index([usuarioId])
  @@index([tenantId])
  @@map("audit_logs")
}

model Notificacao {
  id             String            @id @default(uuid())
  eventoOrigem   String            @map("evento_origem")
  canal          NotificacaoCanal
  status         NotificacaoStatus @default(pendente)
  tentativas     Int               @default(0)
  erro           String?
  payload        Json
  criadoEm       DateTime          @default(now()) @map("criado_em")
