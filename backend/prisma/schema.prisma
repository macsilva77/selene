  qtdDocumentos        Int      @default(0) @map("qtd_documentos")
  vlComprasBruto       Decimal  @default(0) @map("vl_compras_bruto")      @db.Decimal(18, 2)
  qtdDocumentosCompras Int      @default(0) @map("qtd_documentos_compras")
  // CFOPs pré-categorizados na escrita (evita string_agg + JSON parse na leitura)
