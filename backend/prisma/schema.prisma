// ── Certificados Digitais A1 ──────────────────────────────────────────────────

enum CertificadoStatus {
  ATIVO
  VENCIDO
  REVOGADO
  INVALIDO
  EXPIRACAO_PROXIMA
}

enum CertificadoAcao {
  UPLOAD
  ASSOCIACAO
  USO
  REMOCAO
  VISUALIZACAO
}

model CertificadoDigital {
  id             String               @id @default(uuid())
  tenantId       String               @map("tenant_id")
  razaoSocial    String               @map("razao_social")
  cnpjCert       String               @map("cnpj_cert")
  raizCnpj       String               @map("raiz_cnpj")
  numeroSerie    String               @map("numero_serie")
  autoridadeCert String               @map("autoridade_cert")
  dataEmissao    DateTime             @map("data_emissao")
  dataValidade   DateTime             @map("data_validade")
  thumbprint     String
  status         CertificadoStatus
  arquivoEnc     Bytes?               @map("arquivo_enc")
  storageIv      String?              @map("storage_iv")
  /// Certificado público em PEM, criptografado AES-256-GCM
  certPemEnc     Bytes?               @map("cert_pem_enc")
  certPemIv      String?              @map("cert_pem_iv")
  /// Chave privada em PEM, criptografada AES-256-GCM
  keyPemEnc      Bytes?               @map("key_pem_enc")
  keyPemIv       String?              @map("key_pem_iv")
  /// Senha do PFX original, criptografada AES-256-GCM (necessário para ReceitaNetBX/JSignNet)
  senhaEnc       Bytes?               @map("senha_enc")
  senhaIv        String?              @map("senha_iv")
  nomeArquivo    String?              @map("nome_arquivo")
  ativo          Boolean              @default(true)
  criadoEm      DateTime              @default(now()) @map("criado_em")
  atualizadoEm  DateTime              @updatedAt @map("atualizado_em")
  criadoPorId   String                @map("criado_por_id")

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  criadoPor     Usuario               @relation("CertCriadoPor", fields: [criadoPorId], references: [id])
  empresas      CertificadoEmpresa[]
  procuracao    ProcuracaoEletronica?
  logs          CertificadoLog[]
  dfeConfigs    DfeConfig[]
  cteConfigs    CteConfig[]

  @@unique([tenantId, thumbprint])
  @@index([tenantId, status])
  @@index([tenantId, raizCnpj])
  @@map("certificados_digitais")
}

model CertificadoEmpresa {
  certificadoId String             @map("certificado_id")
  empresaId     String             @map("empresa_id")
  associadoEm   DateTime           @default(now()) @map("associado_em")

  certificado   CertificadoDigital @relation(fields: [certificadoId], references: [id])
  empresa       Empresa            @relation(fields: [empresaId], references: [id])

  @@id([certificadoId, empresaId])
  @@map("certificados_empresas")
}

model ProcuracaoEletronica {
  id               String             @id @default(uuid())
  certificadoId    String             @unique @map("certificado_id")
  cnpjOutorgante   String             @map("cnpj_outorgante")
  cpfCnpjOutorgado String             @map("cpf_cnpj_outorgado")
  nomeOutorgado    String             @map("nome_outorgado")
  poderesDelegados String             @map("poderes_delegados")
  dataInicio       DateTime           @map("data_inicio")           @db.Date
  dataValidade     DateTime           @map("data_validade_proc")    @db.Date
  storageKey       String?            @map("storage_key")
  nomeArquivo      String?            @map("nome_arquivo")
  criadoEm        DateTime            @default(now())               @map("criado_em")

  certificado      CertificadoDigital @relation(fields: [certificadoId], references: [id])

  @@map("procuracoes_eletronicas")
}

model CertificadoLog {
  id            BigInt             @id @default(autoincrement())
  certificadoId String             @map("certificado_id")
  tenantId      String             @map("tenant_id")
  usuarioId     String?            @map("usuario_id")
  usuarioNome   String?            @map("usuario_nome")
  acao          CertificadoAcao
  descricao     String?
  ipOrigem      String?            @map("ip_origem")
  criadoEm      DateTime           @default(now()) @map("criado_em")

  certificado   CertificadoDigital @relation(fields: [certificadoId], references: [id])

  @@index([certificadoId])
  @@index([tenantId, criadoEm])
  @@map("certificados_logs")
}

enum ConviteCertificadoStatus {
  PENDENTE
  USADO
  EXPIRADO
  REVOGADO
}

/// Convite de onboarding: link público para o cliente enviar o próprio certificado A1.
/// A empresa é criada automaticamente a partir dos dados do certificado quando o convite é usado.
model CertificadoConvite {
  id             String                   @id @default(uuid())
  tenantId       String                   @map("tenant_id")
  /// sha256(rawToken) — o token cru nunca é persistido
  tokenHash      String                   @unique @map("token_hash")
  email          String
  /// Apelido para o admin localizar o convite (ex.: "Padaria do João")
  apelido        String?
  status         ConviteCertificadoStatus @default(PENDENTE)
  expiraEm       DateTime                 @map("expira_em")
  usadoEm        DateTime?                @map("usado_em")
  ipUso          String?                  @map("ip_uso")
  criadoPorId    String                   @map("criado_por_id")
  /// Certificado gerado ao concluir (rastreio)
  certificadoId  String?                  @map("certificado_id")
  /// Empresa criada/associada ao concluir (rastreio)
  empresaId      String?                  @map("empresa_id")
  /// Razão social / CNPJ lidos do certificado enviado (preenchidos na conclusão)
  razaoSocial    String?                  @map("razao_social")
  cnpj           String?
  criadoEm       DateTime                 @default(now()) @map("criado_em")
  atualizadoEm   DateTime                 @updatedAt @map("atualizado_em")

  tenant         Tenant                   @relation(fields: [tenantId], references: [id])
  criadoPor      Usuario                  @relation("ConviteCertCriadoPor", fields: [criadoPorId], references: [id])

  @@index([tenantId, status])
  @@map("certificados_convites")
}

// ── Distribuição de DF-e (NF-e / CT-e / NFS-e) ───────────────────────────────

enum DfeLoteStatus {
  RECEBIDO
  PROCESSANDO
  PROCESSADO
  ERRO
  REPROCESSAR
}

enum DfeTipoDocumento {
  PROC_NFE
  PROC_EVENTO_NFE
  RES_NFE
  RES_EVENTO
}

/// Configuração de monitoramento DF-e por CNPJ/tenant
model DfeConfig {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  /// CNPJ monitorado, 14 dígitos sem máscara
  cnpj          String
  /// Código IBGE da UF (ex: 35 = SP, 41 = PR, 43 = RS)
  cUf           Int      @map("c_uf")
  /// 1 = produção, 2 = homologação
  tpAmb         Int      @default(1) @map("tp_amb")
  certificadoId String   @map("certificado_id")
  ativo         Boolean  @default(true)
  /// Horário de captura no formato "HH:MM" (ex: "08:00")
  horarioCaptura  String  @default("00:00") @map("horario_captura")
  /// Intervalo em minutos entre execuções (ex: 60 = a cada 1h)
  intervaloMinutos Int   @default(60) @map("intervalo_minutos")
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")
  criadoPorId   String   @map("criado_por_id")

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  certificado CertificadoDigital @relation(fields: [certificadoId], references: [id])
  criadoPor   Usuario            @relation("DfeConfigCriadoPor", fields: [criadoPorId], references: [id])
  controle    DfeNsuControle?
  gaps        DfeGapNsu[]
  varredura   DfeVarreduraNsu?

  @@unique([tenantId, cnpj])
  @@index([tenantId, ativo])
  @@map("dfe_configs")
}

/// Controle de NSU com lock distribuído por CNPJ
model DfeNsuControle {
  id                String    @id @default(uuid())
  configId          String    @unique @map("config_id")
  tenantId          String    @map("tenant_id")
  cnpj              String
  /// Último NSU processado com sucesso (15 dígitos, zero-padded)
  ultimoNsu         String    @default("000000000000000") @map("ultimo_nsu")
  /// maxNSU recebido na última resposta da SEFAZ
  maxNsu            String    @default("000000000000000") @map("max_nsu")
  ultimaConsulta    DateTime? @map("ultima_consulta")
  proximaConsulta   DateTime? @map("proxima_consulta")
  // — lock distribuído —
  emProcessamento   Boolean   @default(false) @map("em_processamento")
  lockId            String?   @map("lock_id")
  lockAte           DateTime? @map("lock_ate")
  /// "hostname:pid" do processo que detém o lock
  lockProcessoId    String?   @map("lock_processo_id")
  // — estatísticas —
  totalDocBaixados  Int       @default(0) @map("total_doc_baixados")
  totalLotes        Int       @default(0) @map("total_lotes")
  totalErros        Int       @default(0) @map("total_erros")
  ultimoErro        String?   @map("ultimo_erro")
  ultimoErroEm      DateTime? @map("ultimo_erro_em")
  errosConsecutivos Int       @default(0) @map("erros_consecutivos")
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")

  config DfeConfig @relation(fields: [configId], references: [id])
  lotes  DfeLote[]

  @@unique([tenantId, cnpj])
  @@index([proximaConsulta, emProcessamento])
  @@map("dfe_nsu_controles")
}

/// Lote de requisição à SEFAZ — cada chamada ao web service gera um lote
model DfeLote {
  id             String        @id @default(uuid())
  controleId     String        @map("controle_id")
  tenantId       String        @map("tenant_id")
  cnpj           String
  /// NSU enviado na requisição
  nsuEnviado     String        @map("nsu_enviado")
  cStat          String        @map("c_stat")
  xMotivo        String        @map("x_motivo")
  ultNsuRecebido String        @map("ult_nsu_recebido")
  maxNsuRecebido String        @map("max_nsu_recebido")
  qtdDocumentos  Int           @default(0) @map("qtd_documentos")
  status         DfeLoteStatus @default(RECEBIDO)
  tentativas     Int           @default(1)
  duracaoMs      Int?          @map("duracao_ms")
  iniciadoEm     DateTime      @default(now()) @map("iniciado_em")
  finalizadoEm   DateTime?     @map("finalizado_em")
  erroMensagem   String?       @map("erro_mensagem")

  controle   DfeNsuControle @relation(fields: [controleId], references: [id])
  documentos DfeDocumento[]

  @@index([tenantId, cnpj, status])
  @@index([tenantId, iniciadoEm])
  @@index([controleId, status])
  @@map("dfe_lotes")
}

/// Documento fiscal eletrônico baixado da SEFAZ
model DfeDocumento {
  id               String           @id @default(uuid())
  loteId           String           @map("lote_id")
  tenantId         String           @map("tenant_id")
  cnpjDestinatario String           @map("cnpj_destinatario")
  /// NSU do documento (15 dígitos, zero-padded) — chave natural
  nsu              String
  /// Schema XML conforme SEFAZ (ex: "procNFe_v4.00.xsd")
  schema           String
  tipoDocumento    DfeTipoDocumento @map("tipo_documento")
  /// XML original descomprimido — null quando armazenado no GCS (ver xmlStoragePath)
  xmlOriginal      Bytes?           @map("xml_original")
  /// Path do XML no Google Cloud Storage (ex: xmls/{tenantId}/{cnpj}/{nsu}.xml)
  xmlStoragePath   String?          @map("xml_storage_path") @db.VarChar(500)
  /// SHA-256 do XML para validação de integridade
  xmlHash          String           @map("xml_hash")
  chaveAcesso      String?          @map("chave_acesso")
  nfeEmitenteCnpj  String?          @map("nfe_emitente_cnpj")
  nfeEmitenteNome  String?          @map("nfe_emitente_nome")
  nfeValorTotal    Decimal?         @map("nfe_valor_total") @db.Decimal(15, 2)
  nfeDhEmissao     DateTime?        @map("nfe_dh_emissao")
  nfeSituacao           String?          @map("nfe_situacao")
  eventoTipo            String?          @map("evento_tipo")
  eventoDescricao       String?          @map("evento_descricao")
  nfeTransportadorCnpj  String?          @map("nfe_transportador_cnpj")
  nfeAutXmlCnpjs        String?          @map("nfe_autxml_cnpjs")
  nfeDestinatarioCnpj   String?          @map("nfe_destinatario_cnpj")
  processado       Boolean          @default(false)
  processadoEm     DateTime?        @map("processado_em")
  erroProcessamento String?         @map("erro_processamento")
  criadoEm         DateTime         @default(now()) @map("criado_em")

  lote              DfeLote                @relation(fields: [loteId], references: [id])
  manifestacoes     DfeManifestacao[]
  gapsRecuperados   DfeGapNsu[]
  etiquetas         DfeDocumentoEtiqueta[]
  etiquetaHistorico EtiquetaHistorico[]

  /// Idempotência: mesmo NSU nunca é inserido duas vezes por tenant
  @@unique([tenantId, nsu])
  @@index([tenantId, cnpjDestinatario])
  @@index([tenantId, nfeDestinatarioCnpj])
  @@index([tenantId, chaveAcesso])
  @@index([tenantId, tipoDocumento])
  @@index([tenantId, processado])
  @@index([tenantId, nfeDhEmissao])
  @@map("dfe_documentos")
}

/// Trilha de auditoria de todas as operações NSU/DF-e
model DfeAuditoria {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  cnpj      String
  operacao  String
  nsuAntes  String?  @map("nsu_antes")
  nsuDepois String?  @map("nsu_depois")
  cStat     String?  @map("c_stat")
  sucesso   Boolean
  detalhe   String?  @db.Text
  duracaoMs Int?     @map("duracao_ms")
  hostname  String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@index([tenantId, cnpj, criadoEm])
  @@index([tenantId, sucesso])
  @@map("dfe_auditorias")
}

// ── Controle de lacunas NSU (gaps) ────────────────────────────────────────────

enum DfeGapStatus {
  /// Gap detectado, aguarda tentativa de recuperação via consNSU
  PENDENTE
  /// SEFAZ retornou cStat=138 — documento recuperado com sucesso
  RECUPERADO
  /// SEFAZ retornou cStat=137 — NSU não existe no Ambiente Nacional
  INEXISTENTE
  /// Máximo de tentativas atingido sem resposta definitiva
  ESGOTADO
}

/// Lacuna NSU detectada entre documentos consecutivos de um lote.
/// Recuperada pontualmente via consNSU conforme MOC 7.0 seção 5.7.4.5.
model DfeGapNsu {
  id              String       @id @default(uuid())
  tenantId        String       @map("tenant_id")
  cnpj            String
  configId        String       @map("config_id")
  /// NSU identificado como faltante (15 dígitos zero-padded)
  nsuFaltante     String       @map("nsu_faltante")
  status          DfeGapStatus @default(PENDENTE)
  tentativas      Int          @default(0)
  /// NSU do documento anterior que gerou a detecção do gap
  nsuAnterior     String       @map("nsu_anterior")
  /// NSU do documento posterior que confirmou o gap
  nsuPosterior    String       @map("nsu_posterior")
  proximaTentativa DateTime?   @map("proxima_tentativa")
  recuperadoEm    DateTime?    @map("recuperado_em")
  /// ID do DfeDocumento inserido após recuperação bem-sucedida
  documentoId     String?      @map("documento_id")
  erroMensagem    String?      @map("erro_mensagem") @db.Text
  criadoEm        DateTime     @default(now()) @map("criado_em")
  atualizadoEm    DateTime     @updatedAt @map("atualizado_em")

  config    DfeConfig     @relation(fields: [configId], references: [id])
  documento DfeDocumento? @relation(fields: [documentoId], references: [id])

  /// Garante que o mesmo NSU faltante não seja registrado duas vezes por tenant
  @@unique([tenantId, nsuFaltante])
  @@index([tenantId, cnpj, status])
  @@index([status, proximaTentativa])
  @@index([configId, status])
  @@map("dfe_gap_nsus")
}

// ── Varredura retroativa de NSU ───────────────────────────────────────────────

enum DfeVarreduraStatus {
  /// Varredura em execução pelo job
  ATIVA
  /// Varredura pausada pelo usuário ou aguardando retomada
  PAUSADA
  /// Varredura concluída (alcançou nsuFim)
  CONCLUIDA
  /// Varredura encerrada por erro não-recuperável
  ERRO
}

/// Varredura retroativa: itera NSUs via consNSU para recuperar documentos
/// não enfileirados na distribuição normal (anteriores ao primeiro distNSU).
model DfeVarreduraNsu {
  id               String             @id @default(uuid())
  /// Um único registro por configuração (upsert ao iniciar nova varredura)
  configId         String             @unique @map("config_id")
  tenantId         String             @map("tenant_id")
  cnpj             String
  status           DfeVarreduraStatus @default(PAUSADA)
  /// NSU inicial da varredura (15 dígitos, zero-padded)
  nsuInicio        String             @map("nsu_inicio")
  /// NSU final da varredura (15 dígitos) — geralmente maxNSU no momento do início
  nsuFim           String             @map("nsu_fim")
  /// NSU atual sendo processado — atualizado a cada lote
  nsuAtual         String             @map("nsu_atual")
  /// Quantidade de NSUs já consultados
  totalConsultado  Int                @default(0) @map("total_consultado")
  /// Quantidade de documentos recuperados (cStat=138)
  totalRecuperado  Int                @default(0) @map("total_recuperado")
  iniciadoEm       DateTime?          @map("iniciado_em")
  pausadoEm        DateTime?          @map("pausado_em")
  concluidoEm      DateTime?          @map("concluido_em")
  ultimoErro       String?            @map("ultimo_erro") @db.Text
  criadoEm         DateTime           @default(now()) @map("criado_em")
  atualizadoEm     DateTime           @updatedAt @map("atualizado_em")

  config DfeConfig @relation(fields: [configId], references: [id])

  @@index([tenantId, status])
  @@map("dfe_varreduras_nsu")
}

// ── Etiquetas ─────────────────────────────────────────────────────────────────

/// Etiqueta de classificação aplicável a documentos fiscais (DfeDocumento).
/// Uniqueness de nome e cor é validada em nível de serviço (ativas por tenant),
/// pois o soft-delete (deletadoEm) impede o uso de unique constraints no banco.
model Etiqueta {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  nome         String    @db.VarChar(100)
  cor          String    @db.VarChar(7)
  /// Apenas uma etiqueta por tenant pode ter padrao=true (troca atômica no serviço)
  padrao       Boolean   @default(false)
  /// Soft delete — registros com deletadoEm != null são ignorados nas consultas
  deletadoEm   DateTime? @map("deletado_em")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  tenant         Tenant                  @relation(fields: [tenantId], references: [id])
  documentos     DfeDocumentoEtiqueta[]
  nfseDocumentos NfseDocumentoEtiqueta[]
  cteDocumentos  CteDocumentoEtiqueta[]

  @@index([tenantId, deletadoEm])
  @@map("etiquetas")
}

/// Tabela de junção entre DfeDocumento e Etiqueta.
model DfeDocumentoEtiqueta {
  id          String   @id @default(uuid())
  documentoId String   @map("documento_id")
  etiquetaId  String   @map("etiqueta_id")
  criadoEm    DateTime @default(now()) @map("criado_em")

  documento DfeDocumento @relation(fields: [documentoId], references: [id])
  etiqueta  Etiqueta     @relation(fields: [etiquetaId], references: [id])

  @@unique([documentoId, etiquetaId])
  @@index([etiquetaId])
  @@map("dfe_documento_etiquetas")
}

/// Histórico imutável de alterações de etiquetas em documentos fiscais.
/// Gerado automaticamente em toda operação de associação/desassociação (individual ou em massa).
/// Sem updatedAt — imutável por design.
model EtiquetaHistorico {
  id              String   @id @default(uuid())
  documentoId     String   @map("documento_id")
  usuarioId       String?  @map("usuario_id")
  /// Snapshot das etiquetas antes da alteração (array de {id, nome, cor})
  etiquetasAntes  Json     @map("etiquetas_antes")
  /// Snapshot das etiquetas depois da alteração (array de {id, nome, cor})
  etiquetasDepois Json     @map("etiquetas_depois")
  criadoEm        DateTime @default(now()) @map("criado_em")

  documento DfeDocumento @relation(fields: [documentoId], references: [id])
  usuario   Usuario?     @relation(fields: [usuarioId], references: [id])

  @@index([documentoId, criadoEm])
  @@map("etiqueta_historico")
}

// ── Manifestação do Destinatário ──────────────────────────────────────────────

enum DfeManifestacaoStatus {
  /// Aguarda envio à SEFAZ
  PENDENTE
  /// Enviado com sucesso (cStat=135)
  ENVIADO
  /// Rejeitado pela SEFAZ (cStat de rejeição)
  REJEITADO
  /// Falha técnica (rede, timeout) — será retentado
  ERRO
}

/// Evento de manifestação do destinatário enviado ao WS NFeRecepcaoEvento.
/// Cobre os quatro tipos oficiais do MOC 7.0 seção 5.11:
///   210200 – Ciência da Operação
///   210210 – Confirmação da Operação
///   210220 – Operação não Realizada
///   210240 – Desconhecimento da Operação
model DfeManifestacao {
  id           String                 @id @default(uuid())
  tenantId     String                 @map("tenant_id")
  cnpj         String
  documentoId  String                 @map("documento_id")
  chaveAcesso  String                 @map("chave_acesso") @db.VarChar(44)
  /// Código do evento conforme MOC (ex: "210200")
  tpEvento     String                 @map("tp_evento") @db.VarChar(6)
  /// Descrição textual conforme MOC (ex: "Ciência da Operação")
  xEvento      String                 @map("x_evento") @db.VarChar(60)
  /// Sequencial do evento para o mesmo tipo (1 ou 2)
  nSeqEvento   Int                    @default(1) @map("n_seq_evento")
  /// Justificativa — obrigatória para tpEvento=210220, mínimo 15 chars
  xJust        String?                @map("x_just") @db.VarChar(255)
  status       DfeManifestacaoStatus  @default(PENDENTE)
  tentativas   Int                    @default(0)
  /// Número de protocolo retornado pela SEFAZ após sucesso
  nProt        String?                @map("n_prot") @db.VarChar(15)
  cStat        String?                @map("c_stat") @db.VarChar(3)
  xMotivo      String?                @map("x_motivo") @db.VarChar(255)
  dhRegEvento  DateTime?              @map("dh_reg_evento")
  /// XML do envelope enviado (armazenado para auditoria e reprocessamento)
  xmlEnvio     Bytes?                 @map("xml_envio")
  /// XML da resposta bruta da SEFAZ
  xmlResposta  Bytes?                 @map("xml_resposta")
  erroMensagem String?                @map("erro_mensagem") @db.Text
  criadoEm     DateTime               @default(now()) @map("criado_em")
  enviadoEm    DateTime?              @map("enviado_em")
  atualizadoEm DateTime               @updatedAt @map("atualizado_em")

  documento DfeDocumento @relation(fields: [documentoId], references: [id])

  /// Um tipo de evento por chave de acesso por tenant é único (nSeqEvento controla reenvios)
  @@unique([tenantId, chaveAcesso, tpEvento, nSeqEvento])
  @@index([tenantId, cnpj, status])
  @@index([tenantId, chaveAcesso])
  @@index([status, criadoEm])
  @@index([documentoId])
  @@map("dfe_manifestacoes")
}

// ── Exportação de DANFE ───────────────────────────────────────────────────────

enum DfeExportJobStatus {
  PENDENTE
  PROCESSANDO
  CONCLUIDO
  ERRO
}

/// Job de exportação em lote de DANFEs — geração de PDF + ZIP + envio por e-mail
model DfeExportJob {
  id              String             @id @default(uuid())
  tenantId        String             @map("tenant_id")
  usuarioId       String?            @map("usuario_id")
  status          DfeExportJobStatus @default(PENDENTE)
  email           String?
  documentoIds    String             @map("documento_ids") @db.Text
  totalDocs       Int                @default(0) @map("total_docs")
  docsProcessados Int                @default(0) @map("docs_processados")
  arquivoNome     String?            @map("arquivo_nome")
  erroMensagem    String?            @map("erro_mensagem") @db.Text
  criadoEm        DateTime           @default(now()) @map("criado_em")
  atualizadoEm    DateTime           @updatedAt @map("atualizado_em")
  expiradoEm      DateTime?          @map("expirado_em")

  @@index([tenantId, status])
  @@index([tenantId, criadoEm])
  @@map("dfe_export_jobs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// Distribuição de DF-e do CT-e (modelo 57 / CT-e OS 67 / GTV-e 64)
// Web Service CTeDistribuicaoDFe (NT 2015.002 v1.05). Módulo isolado do DFe NF-e.
// Ver documentacaoCte/CTe-DFe-ESPECIFICACAO.md
// ═══════════════════════════════════════════════════════════════════════════════

enum CteLoteStatus {
  RECEBIDO
  PROCESSANDO
  PROCESSADO
  ERRO
  REPROCESSAR
}

enum CteTipoDocumento {
  /// CT-e processado (cteProc) — documento completo
  PROC_CTE
  /// Evento processado (procEventoCTe)
  PROC_EVENTO_CTE
  /// Resumo de CT-e — reservado; a distribuição do CT-e aparentemente entrega o
  /// procCTe completo direto (confirmar no pacote XSD). Mantido por simetria.
  RES_CTE
  /// Resumo de evento — reservado
  RES_EVENTO_CTE
}

enum CteGapStatus {
  PENDENTE
  RECUPERADO
  INEXISTENTE
  ESGOTADO
}

enum CteVarreduraStatus {
  ATIVA
  PAUSADA
  CONCLUIDA
  ERRO
}

enum CteEventoStatus {
  PENDENTE
  ENVIADO
  REJEITADO
  ERRO
}

/// Configuração de monitoramento de distribuição CT-e por CNPJ/tenant
model CteConfig {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  /// CNPJ monitorado, 14 dígitos sem máscara
  cnpj          String
  /// Código IBGE da UF (ex: 35 = SP, 41 = PR, 43 = RS)
  cUf           Int      @map("c_uf")
  /// 1 = produção, 2 = homologação
  tpAmb         Int      @default(1) @map("tp_amb")
  certificadoId String   @map("certificado_id")
  ativo         Boolean  @default(true)
  /// Horário de captura no formato "HH:MM" (ex: "08:00")
  horarioCaptura   String @default("00:00") @map("horario_captura")
  /// Intervalo em minutos entre execuções (ex: 60 = a cada 1h)
  intervaloMinutos Int    @default(60) @map("intervalo_minutos")
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")
  criadoPorId   String   @map("criado_por_id")

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  certificado CertificadoDigital @relation(fields: [certificadoId], references: [id])
  criadoPor   Usuario            @relation("CteConfigCriadoPor", fields: [criadoPorId], references: [id])
  controle    CteNsuControle?
  gaps        CteGapNsu[]
  varredura   CteVarreduraNsu?

  @@unique([tenantId, cnpj])
  @@index([tenantId, ativo])
  @@map("cte_configs")
}

/// Controle de NSU com lock distribuído por CNPJ (sequência de NSU própria do AN do CT-e)
model CteNsuControle {
  id                String    @id @default(uuid())
  configId          String    @unique @map("config_id")
  tenantId          String    @map("tenant_id")
  cnpj              String
  /// Último NSU processado com sucesso (15 dígitos, zero-padded)
  ultimoNsu         String    @default("000000000000000") @map("ultimo_nsu")
  /// maxNSU recebido na última resposta da SEFAZ
  maxNsu            String    @default("000000000000000") @map("max_nsu")
  ultimaConsulta    DateTime? @map("ultima_consulta")
  proximaConsulta   DateTime? @map("proxima_consulta")
  // — lock distribuído —
  emProcessamento   Boolean   @default(false) @map("em_processamento")
  lockId            String?   @map("lock_id")
  lockAte           DateTime? @map("lock_ate")
  /// "hostname:pid" do processo que detém o lock
  lockProcessoId    String?   @map("lock_processo_id")
  // — estatísticas —
  totalDocBaixados  Int       @default(0) @map("total_doc_baixados")
  totalLotes        Int       @default(0) @map("total_lotes")
  totalErros        Int       @default(0) @map("total_erros")
  ultimoErro        String?   @map("ultimo_erro")
  ultimoErroEm      DateTime? @map("ultimo_erro_em")
  errosConsecutivos Int       @default(0) @map("erros_consecutivos")
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")

  config CteConfig @relation(fields: [configId], references: [id])
  lotes  CteLote[]

  @@unique([tenantId, cnpj])
  @@index([proximaConsulta, emProcessamento])
  @@map("cte_nsu_controles")
}

/// Lote de requisição à SEFAZ — cada chamada ao CTeDistribuicaoDFe gera um lote
model CteLote {
  id             String        @id @default(uuid())
  controleId     String        @map("controle_id")
  tenantId       String        @map("tenant_id")
  cnpj           String
  /// NSU enviado na requisição (distNSU)
  nsuEnviado     String        @map("nsu_enviado")
  cStat          String        @map("c_stat")
  xMotivo        String        @map("x_motivo")
  ultNsuRecebido String        @map("ult_nsu_recebido")
  maxNsuRecebido String        @map("max_nsu_recebido")
  qtdDocumentos  Int           @default(0) @map("qtd_documentos")
  status         CteLoteStatus @default(RECEBIDO)
  tentativas     Int           @default(1)
  duracaoMs      Int?          @map("duracao_ms")
  iniciadoEm     DateTime      @default(now()) @map("iniciado_em")
  finalizadoEm   DateTime?     @map("finalizado_em")
  erroMensagem   String?       @map("erro_mensagem")

  controle   CteNsuControle @relation(fields: [controleId], references: [id])
  documentos CteDocumento[]

  @@index([tenantId, cnpj, status])
  @@index([tenantId, iniciadoEm])
  @@index([controleId, status])
  @@map("cte_lotes")
}

/// Documento (CT-e / CT-e OS / GTV-e ou evento) baixado da distribuição
model CteDocumento {
  id               String           @id @default(uuid())
  loteId           String           @map("lote_id")
  tenantId         String           @map("tenant_id")
  /// CNPJ interessado para o qual a distribuição foi consultada (config)
  cnpjInteressado  String           @map("cnpj_interessado")
  /// NSU do documento (15 dígitos, zero-padded) — chave natural
  nsu              String
  /// Schema XML conforme SEFAZ (ex: "procCTe_v4.00.xsd")
  schema           String
  tipoDocumento    CteTipoDocumento @map("tipo_documento")
  /// Modelo fiscal: 57 = CT-e, 67 = CT-e OS, 64 = GTV-e
  modelo           Int?
  /// XML original descomprimido — null quando armazenado no GCS (ver xmlStoragePath)
  xmlOriginal      Bytes?           @map("xml_original")
  /// Path do XML no Google Cloud Storage (ex: cte/{tenantId}/{cnpj}/{nsu}.xml)
  xmlStoragePath   String?          @map("xml_storage_path") @db.VarChar(500)
  /// SHA-256 do XML para validação de integridade
  xmlHash          String           @map("xml_hash")
  chaveAcesso      String?          @map("chave_acesso")
  // — dados do CT-e —
  cteEmitenteCnpj   String?  @map("cte_emitente_cnpj")
  cteEmitenteNome   String?  @map("cte_emitente_nome")
  /// vTPrest — valor total da prestação do serviço
  cteValorPrestacao Decimal? @map("cte_valor_prestacao") @db.Decimal(15, 2)
  /// vRec — valor a receber
  cteValorReceber   Decimal? @map("cte_valor_receber") @db.Decimal(15, 2)
  cteDhEmissao      DateTime? @map("cte_dh_emissao")
  cteSituacao       String?  @map("cte_situacao")
  /// tpCTe: 0 = normal, 1 = complementar, 2 = anulação, 3 = substituto
  tpCte             Int?     @map("tp_cte")
  cfop              String?
  /// Modal: 01 rodoviário, 02 aéreo, 03 aquaviário, 04 ferroviário, 05 dutoviário, 06 multimodal
  modal             String?
  /// UF de início da prestação (sigla)
  ufIni             String?  @map("uf_ini")
  /// UF de fim da prestação (sigla)
  ufFim             String?  @map("uf_fim")
  // — papéis (usados como filtros de listagem) —
  cteTomadorCnpj      String? @map("cte_tomador_cnpj")
  cteRemetenteCnpj    String? @map("cte_remetente_cnpj")
  cteDestinatarioCnpj String? @map("cte_destinatario_cnpj")
  cteExpedidorCnpj    String? @map("cte_expedidor_cnpj")
  cteRecebedorCnpj    String? @map("cte_recebedor_cnpj")
  /// Chaves das NF-e transportadas (CSV) — permite cruzar com o DFe da NF-e
  cteChavesNfe        String? @map("cte_chaves_nfe") @db.Text
  // — eventos —
  eventoTipo        String?  @map("evento_tipo")
  eventoDescricao   String?  @map("evento_descricao")
  processado        Boolean  @default(false)
  processadoEm      DateTime? @map("processado_em")
  erroProcessamento String?  @map("erro_processamento")
  criadoEm          DateTime @default(now()) @map("criado_em")

  lote              CteLote                @relation(fields: [loteId], references: [id])
  eventos           CteEvento[]
  gapsRecuperados   CteGapNsu[]
  etiquetas         CteDocumentoEtiqueta[]
  etiquetaHistorico CteEtiquetaHistorico[]

  /// Idempotência: mesmo NSU nunca é inserido duas vezes por tenant
  @@unique([tenantId, nsu])
  @@index([tenantId, cnpjInteressado])
  @@index([tenantId, cteTomadorCnpj])
  @@index([tenantId, cteRemetenteCnpj])
  @@index([tenantId, cteDestinatarioCnpj])
  @@index([tenantId, chaveAcesso])
  @@index([tenantId, tipoDocumento])
  @@index([tenantId, modelo])
  @@index([tenantId, processado])
  @@index([tenantId, cteDhEmissao])
  @@map("cte_documentos")
}

/// Trilha de auditoria de todas as operações NSU/DF-e do CT-e
model CteAuditoria {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  cnpj      String
  operacao  String
  nsuAntes  String?  @map("nsu_antes")
  nsuDepois String?  @map("nsu_depois")
  cStat     String?  @map("c_stat")
  sucesso   Boolean
  detalhe   String?  @db.Text
  duracaoMs Int?     @map("duracao_ms")
  hostname  String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@index([tenantId, cnpj, criadoEm])
  @@index([tenantId, sucesso])
  @@map("cte_auditorias")
}

/// Lacuna NSU detectada entre documentos consecutivos. Recuperada via consNSU.
model CteGapNsu {
  id               String       @id @default(uuid())
  tenantId         String       @map("tenant_id")
  cnpj             String
  configId         String       @map("config_id")
  nsuFaltante      String       @map("nsu_faltante")
  status           CteGapStatus @default(PENDENTE)
  tentativas       Int          @default(0)
  nsuAnterior      String       @map("nsu_anterior")
  nsuPosterior     String       @map("nsu_posterior")
  proximaTentativa DateTime?    @map("proxima_tentativa")
  recuperadoEm     DateTime?    @map("recuperado_em")
  documentoId      String?      @map("documento_id")
  erroMensagem     String?      @map("erro_mensagem") @db.Text
  criadoEm         DateTime     @default(now()) @map("criado_em")
  atualizadoEm     DateTime     @updatedAt @map("atualizado_em")

  config    CteConfig     @relation(fields: [configId], references: [id])
  documento CteDocumento? @relation(fields: [documentoId], references: [id])

  @@unique([tenantId, cnpj, nsuFaltante])
  @@index([tenantId, cnpj, status])
  @@index([status, proximaTentativa])
  @@index([configId, status])
  @@map("cte_gap_nsus")
}

/// Varredura retroativa de NSU via consNSU (recupera documentos antigos)
model CteVarreduraNsu {
  id              String             @id @default(uuid())
  configId        String             @unique @map("config_id")
  tenantId        String             @map("tenant_id")
  cnpj            String
  status          CteVarreduraStatus @default(PAUSADA)
  nsuInicio       String             @map("nsu_inicio")
  nsuFim          String             @map("nsu_fim")
  nsuAtual        String             @map("nsu_atual")
  totalConsultado Int                @default(0) @map("total_consultado")
  totalRecuperado Int                @default(0) @map("total_recuperado")
  iniciadoEm      DateTime?          @map("iniciado_em")
  pausadoEm       DateTime?          @map("pausado_em")
  concluidoEm     DateTime?          @map("concluido_em")
  ultimoErro      String?            @map("ultimo_erro") @db.Text
  criadoEm        DateTime           @default(now()) @map("criado_em")
  atualizadoEm    DateTime           @updatedAt @map("atualizado_em")

  config CteConfig @relation(fields: [configId], references: [id])

  @@index([tenantId, status])
  @@map("cte_varreduras_nsu")
}

/// Evento do tomador enviado ao WS CTeRecepcaoEventoV4 (roteado por UF autorizadora).
/// Tipos: 610110 = Prestação do Serviço em Desacordo; 610111 = Cancelamento do Desacordo.
/// O CT-e NÃO usa o modelo de manifestação do destinatário da NF-e (210200/...).
model CteEvento {
  id           String          @id @default(uuid())
  tenantId     String          @map("tenant_id")
  /// CNPJ do autor do evento (tomador do serviço)
  cnpj         String
  documentoId  String          @map("documento_id")
  chaveAcesso  String          @map("chave_acesso") @db.VarChar(44)
  /// Código do evento (ex: "610110")
  tpEvento     String          @map("tp_evento") @db.VarChar(6)
  /// Descrição textual (ex: "Prestacao do servico em desacordo")
  xEvento      String          @map("x_evento") @db.VarChar(60)
  nSeqEvento   Int             @default(1) @map("n_seq_evento")
  /// Observação/justificativa do desacordo — obrigatória, 15 a 255 caracteres
  xObs         String?         @map("x_obs") @db.VarChar(255)
  /// indDesacordoOper — indicador de operação em desacordo
  indDesacordo Boolean         @default(true) @map("ind_desacordo")
  /// UF autorizadora do CT-e (define o endpoint CTeRecepcaoEventoV4 — maioria SVRS)
  ufAutorizador String?        @map("uf_autorizador")
  status       CteEventoStatus @default(PENDENTE)
  tentativas   Int             @default(0)
  nProt        String?         @map("n_prot") @db.VarChar(15)
  cStat        String?         @map("c_stat") @db.VarChar(3)
  xMotivo      String?         @map("x_motivo") @db.VarChar(255)
  dhRegEvento  DateTime?       @map("dh_reg_evento")
  xmlEnvio     Bytes?          @map("xml_envio")
  xmlResposta  Bytes?          @map("xml_resposta")
  erroMensagem String?         @map("erro_mensagem") @db.Text
  criadoEm     DateTime        @default(now()) @map("criado_em")
  enviadoEm    DateTime?       @map("enviado_em")
  atualizadoEm DateTime        @updatedAt @map("atualizado_em")

  documento CteDocumento @relation(fields: [documentoId], references: [id])

  @@unique([tenantId, chaveAcesso, tpEvento, nSeqEvento])
  @@index([tenantId, cnpj, status])
  @@index([tenantId, chaveAcesso])
  @@index([status, criadoEm])
  @@index([documentoId])
  @@map("cte_eventos")
}

/// Tabela de junção entre CteDocumento e Etiqueta (reusa o model Etiqueta genérico)
model CteDocumentoEtiqueta {
  id          String   @id @default(uuid())
  documentoId String   @map("documento_id")
  etiquetaId  String   @map("etiqueta_id")
  criadoEm    DateTime @default(now()) @map("criado_em")

  documento CteDocumento @relation(fields: [documentoId], references: [id])
  etiqueta  Etiqueta     @relation(fields: [etiquetaId], references: [id])

  @@unique([documentoId, etiquetaId])
  @@index([etiquetaId])
  @@map("cte_documento_etiquetas")
}

/// Histórico imutável de alterações de etiquetas em CteDocumento
model CteEtiquetaHistorico {
  id              String   @id @default(uuid())
  documentoId     String   @map("documento_id")
  usuarioId       String?  @map("usuario_id")
  etiquetasAntes  Json     @map("etiquetas_antes")
  etiquetasDepois Json     @map("etiquetas_depois")
  criadoEm        DateTime @default(now()) @map("criado_em")

  documento CteDocumento @relation(fields: [documentoId], references: [id])
  usuario   Usuario?     @relation(fields: [usuarioId], references: [id])

  @@index([documentoId, criadoEm])
  @@map("cte_etiqueta_historico")
}

// ─── SPED ─────────────────────────────────────────────────────────────────────

enum SpedStatus {
  DISPONIVEL
  ERRO
  INDISPONIVEL
}

model SpedArquivo {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  cnpj          String
  tipo          String      // EFD_ICMS | EFD_CONTRIBUICOES | ECD | ECF
  gcsBucket     String      @map("gcs_bucket")
  gcsPath       String      @map("gcs_path")
  nomeArquivo   String      @map("nome_arquivo")
  dataDocumento DateTime    @map("data_documento")
  status        SpedStatus
  mensagemErro  String?     @map("mensagem_erro") @db.Text
  criadoEm      DateTime    @default(now()) @map("criado_em")
  atualizadoEm  DateTime    @updatedAt @map("atualizado_em")

  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, cnpj, tipo, dataDocumento], name: "tenantId_cnpj_tipo_dataDocumento")
  @@index([tenantId, cnpj])
  @@map("sped_arquivos")
}

// ─── OBRIGAÇÕES ACESSÓRIAS ────────────────────────────────────────────────────
// Enums gerenciados na camada de aplicação (RN-03). Banco armazena varchar.

model ObrigacaoAcessoria {
  id                     String              @id @default(uuid())
  idEvento               String              @unique @map("id_evento") @db.VarChar(255)
  tipoObrigacao          String              @map("tipo_obrigacao") @db.VarChar(30)
  cnpj                   String              @db.VarChar(14)
  inscricaoEstadual      String?             @map("inscricao_estadual") @db.VarChar(20)
  dataInicial            DateTime            @map("data_inicial") @db.Date
  dataFinal              DateTime            @map("data_final") @db.Date
  finalidade             String              @db.VarChar(20)
  hash                   String              @db.VarChar(64)
  dataEntrega            DateTime            @map("data_entrega") @db.Timestamptz(6)
  nomeArquivo            String              @map("nome_arquivo") @db.VarChar(500)
  caminhoBucket          String              @map("caminho_bucket") @db.VarChar(1000)
  statusProcessamento    String              @map("status_processamento") @db.VarChar(50)
  origem                 String              @db.VarChar(20)
  versao                 Int                 @default(1)
  versaoAtual            Boolean             @default(true) @map("versao_atual")
  dataRecebimentoEvento  DateTime            @map("data_recebimento_evento") @db.Timestamptz(6)
  obrigacaoPaiId         String?             @map("obrigacao_pai_id")
  criadoEm               DateTime            @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm           DateTime            @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  atualizadoPor          String              @map("atualizado_por") @db.VarChar(255)

  // RN-11: auto-relacionamento para versões/retificações
  obrigacaoPai           ObrigacaoAcessoria?  @relation("ObrigacaoVersoes", fields: [obrigacaoPaiId], references: [id])
  versoes                ObrigacaoAcessoria[] @relation("ObrigacaoVersoes")

  @@index([cnpj, tipoObrigacao, dataInicial, dataFinal])
  @@index([statusProcessamento])
  @@index([versaoAtual])
  @@map("obrigacao_acessoria")
}

// ─── ANÁLISE DE CRÉDITO — P01 ─────────────────────────────────────────────────
// Tabelas geradas pelo pipeline P01 (extração ECD/ECF).
// Chave de negócio: (tenantId, cnpj) → CreditoEmpresa.
// Idempotência controlada por CreditoProcessamento.

model CreditoEmpresa {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  cnpj             String   @db.VarChar(14)
  razaoSocial      String   @map("razao_social")
  regimeTributario String?  @map("regime_tributario") @db.VarChar(30)
  cnaePrincipal    String?  @map("cnae_principal")   @db.VarChar(10)
  statusExtracao   String   @default("completo")     @map("status_extracao")  @db.VarChar(20)
  observacoes      String?  @db.Text
  criadoEm        DateTime @default(now())           @map("criado_em")
  atualizadoEm    DateTime @updatedAt                @map("atualizado_em")

  tenant           Tenant                  @relation(fields: [tenantId], references: [id])
  planoContas      CreditoPlanoConta[]
  ecdSaldos        CreditoEcdSaldo[]
  ecfRegistros     CreditoEcfRegistro[]
  ecfArquivos      CreditoEcfArquivo[]
  inconsistencias  CreditoInconsistencia[]
  processamentos   CreditoProcessamento[]
  balanco           CreditoBalanco[]
  dre               CreditoDre[]
  indicadores        CreditoIndicador[]
  estruturaCapital   CreditoEstruturaCapital[]
  alertas            CreditoAlerta[]
  classificacoes     CreditoClassificacao[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
  @@map("credito_empresas")
}

model CreditoPlanoConta {
  id          String         @id @default(uuid())
  empresaId   String         @map("empresa_id")
  exercicio   Int
  contaCodigo String         @map("conta_codigo") @db.VarChar(30)
  contaNome   String         @map("conta_nome")
  nivel       Int
  natureza    String         @db.VarChar(1)   // D | C
  tipo        String         @db.VarChar(20)  // sintetica | analitica
  grupo       String         @db.VarChar(10)  // AC | ANC | PC | PNC | PL | REC | CUS | DES | RNO

  empresa     CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio, contaCodigo])
  @@index([empresaId, exercicio])
  @@map("credito_plano_contas")
}

model CreditoEcdSaldo {
  id            String         @id @default(uuid())
  empresaId     String         @map("empresa_id")
  exercicio     Int
  periodo       String         @db.VarChar(7)   // AAAA-MM
  contaCodigo   String         @map("conta_codigo") @db.VarChar(30)
  contaNome     String         @map("conta_nome")
  grupo         String?        @db.VarChar(10)
  saldoAnterior Decimal        @default(0) @map("saldo_anterior") @db.Decimal(18, 2)
  debitos       Decimal        @default(0)                        @db.Decimal(18, 2)
  creditos      Decimal        @default(0)                        @db.Decimal(18, 2)
  saldoFinal    Decimal        @default(0) @map("saldo_final")    @db.Decimal(18, 2)
  naturezaSaldo String?        @map("natureza_saldo") @db.VarChar(1)  // D | C
  status        String         @default("ok") @db.VarChar(20)

  empresa       CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio, periodo, contaCodigo])
  @@index([empresaId, exercicio])
  @@map("credito_ecd_saldos")
}

model CreditoEcfRegistro {
  id          String         @id @default(uuid())
  empresaId   String         @map("empresa_id")
  exercicio   Int
  registroEcf String         @map("registro_ecf") @db.VarChar(10) // BP: L100(LR)|P100(LP/LA)|U100(II)  DRE: L300(LR)|P150(LP/LA)|U150(II)  LALUR: M300|M350
  trimestre   Int            @default(0)            @map("trimestre") // 0=anual/não-trimestral  1..4=Q1..Q4
  linhaCodigo String         @map("linha_codigo")  @db.VarChar(50)
  descricao   String         @db.Text
  valor       Decimal        @default(0)            @db.Decimal(18, 2)
  status      String         @default("ok")         @db.VarChar(20)

  empresa     CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio, registroEcf, trimestre, linhaCodigo])
  @@index([empresaId, exercicio])
  @@map("credito_ecf_registros")
}

model CreditoEcfArquivo {
  id           String         @id @default(uuid())
  empresaId    String         @map("empresa_id")
  exercicio    Int
  gcsPath      String         @map("gcs_path")     @db.Text     // path do Parquet no GCS
  gcsPathEcf   String         @map("gcs_path_ecf") @db.Text     // path do ECF .txt original
  trimestres   Int[]                                             // trimestres disponíveis: 0=anual, 1..4=Q1..Q4
  registros    Int            @default(0)                        // total de linhas no Parquet
  hashMd5      String         @map("hash_md5")     @db.VarChar(32)
  criadoEm     DateTime       @default(now())       @map("criado_em")
  atualizadoEm DateTime       @updatedAt            @map("atualizado_em")

  empresa      CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio])
  @@index([empresaId])
  @@map("credito_ecf_arquivos")
}

model CreditoInconsistencia {
  id         String         @id @default(uuid())
  empresaId  String         @map("empresa_id")
  exercicio  Int
  tipoErro   String         @map("tipo_erro")  @db.VarChar(50)
  descricao  String         @db.Text
  severidade String         @default("alerta") @db.VarChar(20) // info | alerta | bloqueio
  criadoEm  DateTime        @default(now())    @map("criado_em")

  empresa    CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@index([empresaId, exercicio])
  @@map("credito_inconsistencias")
}

model CreditoProcessamento {
  id                     String         @id @default(uuid())
  empresaId              String         @map("empresa_id")
  exercicio              Int
  tabelaDestino          String         @map("tabela_destino")         @db.VarChar(50)
  totalRegistros         Int            @default(0) @map("total_registros")
  registrosOk            Int            @default(0) @map("registros_ok")
  registrosComAlerta     Int            @default(0) @map("registros_com_alerta")
  registrosBloqueados    Int            @default(0) @map("registros_bloqueados")
  hashArquivoOrigem      String?        @map("hash_arquivo_origem")    @db.VarChar(64)
  timestampProcessamento DateTime       @map("timestamp_processamento")
  versaoPrompt           String         @default("P01-v1") @map("versao_prompt") @db.VarChar(20)
  duracaoMs              Int?           @map("duracao_ms")

  empresa                CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio, tabelaDestino, versaoPrompt])
  @@index([empresaId, exercicio])
  @@map("credito_processamentos")
}

// ─── ANÁLISE DE CRÉDITO — P02 ─────────────────────────────────────────────────

model CreditoBalanco {
  id          String         @id @default(uuid())
  empresaId   String         @map("empresa_id")
  exercicio   Int
  grupo       String         @db.VarChar(10)   // AC | ANC | PC | PNC | PL
  subgrupo    String         @db.VarChar(60)   // Caixa | Clientes | Estoques ...
  contaCodigo String         @map("conta_codigo") @db.VarChar(30)
  contaNome   String         @map("conta_nome")
  valor       Decimal        @db.Decimal(18, 2)
  fonte       String         @default("ecd_j100") @db.VarChar(20) // ecd_j100 | ecf_l100 | inferido

  empresa     CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio, contaCodigo])
  @@index([empresaId, exercicio])
  @@map("credito_balanco")
}

model CreditoDre {
  id        String         @id @default(uuid())
  empresaId String         @map("empresa_id")
  exercicio Int
  linhaDre  String         @map("linha_dre") @db.VarChar(30)
  // receita_bruta | deducoes | receita_liquida | cmv | lucro_bruto |
  // desp_vendas | desp_admin | desp_financeiras | rec_financeiras |
  // outras_desp | outras_rec | ebit | depreciacao | ebitda | ir_csll | lucro_liquido
  valor     Decimal        @db.Decimal(18, 2)
  fonte     String         @default("ecf_l300") @db.VarChar(20) // ecf_l300 | ecf_l100 | ecd_inferido

  empresa   CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio, linhaDre])
  @@index([empresaId, exercicio])
  @@map("credito_dre")
}

// ─── ANÁLISE DE CRÉDITO — P03 ─────────────────────────────────────────────────

model CreditoIndicador {
  id         String         @id @default(uuid())
  empresaId  String         @map("empresa_id")
  exercicio  Int
  indicador  String         @db.VarChar(50)
  // NULL = SAFE_DIV retornou null (denominador zero ou dado ausente)
  valor      Decimal?       @db.Decimal(18, 6)
  unidade    String         @db.VarChar(15) // ratio | percentual | dias | reais
  fonteOk    Int            @default(1)     @map("fonte_ok") // 0 se entrada inferida

  empresa    CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio, indicador])
  @@index([empresaId, exercicio])
  @@map("credito_indicadores")
}

model CreditoEstruturaCapital {
  id                     String         @id @default(uuid())
  empresaId              String         @map("empresa_id")
  exercicio              Int
  ativoTotal             Decimal?       @map("ativo_total")              @db.Decimal(18, 2)
  passivoTotal           Decimal?       @map("passivo_total")            @db.Decimal(18, 2)
  pl                     Decimal?       @db.Decimal(18, 2)
  dividaFinanceiraCp     Decimal?       @map("divida_financeira_cp")     @db.Decimal(18, 2)
  dividaFinanceiraLp     Decimal?       @map("divida_financeira_lp")     @db.Decimal(18, 2)
  dividaFinanceiraTot    Decimal?       @map("divida_financeira_tot")    @db.Decimal(18, 2)
  dividaLiquida          Decimal?       @map("divida_liquida")           @db.Decimal(18, 2)
  capitalProprioPct      Decimal?       @map("capital_proprio_pct")      @db.Decimal(18, 6)
  capitalTerceirosPct    Decimal?       @map("capital_terceiros_pct")    @db.Decimal(18, 6)
  grauEndividamento      Decimal?       @map("grau_endividamento")       @db.Decimal(18, 6)
  independenciaFinanceira Decimal?      @map("independencia_financeira") @db.Decimal(18, 6)
  relacaoCtCp            Decimal?       @map("relacao_ct_cp")            @db.Decimal(18, 6)
  endivBancarioPl        Decimal?       @map("endiv_bancario_pl")        @db.Decimal(18, 6)
  coberturaJuros         Decimal?       @map("cobertura_juros")          @db.Decimal(18, 6)
  dividaCpPct            Decimal?       @map("divida_cp_pct")            @db.Decimal(18, 6)

  empresa                CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio])
  @@index([empresaId])
  @@map("credito_estrutura_capital")
}

// ─── ANÁLISE DE CRÉDITO — P04 ─────────────────────────────────────────────────

model CreditoAlerta {
  id           String         @id @default(uuid())
  empresaId    String         @map("empresa_id")
  exercicio    Int
  codigoRegra  String         @map("codigo_regra") @db.VarChar(10) // CR-01 | AT-03 | PO-05
  severidade   String         @db.VarChar(10)                      // critico | atencao | positivo
  indicador    String         @db.VarChar(50)
  valorAtual   Decimal?       @map("valor_atual")                  @db.Decimal(18, 6)
  mensagem     String         @db.Text
  categoria    String         @db.VarChar(40)
  regraOk      Int            @default(1) @map("regra_ok")          // 0 se input inferido

  empresa      CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio, codigoRegra])
  @@index([empresaId, exercicio])
  @@map("credito_alertas")
}

model CreditoClassificacao {
  id                 String         @id @default(uuid())
  empresaId          String         @map("empresa_id")
  exercicio          Int
  classificacao      String         @db.VarChar(20) // BAIXO | MEDIO_BAIXO | MEDIO | MEDIO_ALTO | ALTO
  classificacaoNum   Int            @map("classificacao_num") // 1-5
  qtdCriticos        Int            @map("qtd_criticos")
  qtdAtencao         Int            @map("qtd_atencao")
  qtdPositivos       Int            @map("qtd_positivos")
  overrideAplicado   Int            @default(0) @map("override_aplicado") // 1 se elevado por override
  motivoOverride     String?        @map("motivo_override") @db.Text
  confiabilidade     String         @db.VarChar(10) // alta | media | baixa
  dataGeracao        DateTime       @default(now()) @map("data_geracao")

  empresa            CreditoEmpresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, exercicio])
  @@index([empresaId])
  @@map("credito_classificacoes")
}

model CreditoRegra {
  id               String   @id @default(uuid())
  codigoRegra      String   @unique @map("codigo_regra") @db.VarChar(10)  // CR-01 | AT-03 | PO-05
  nome             String   @db.VarChar(100)
  descricao        String?  @db.Text
  severidade       String   @db.VarChar(10)   // critico | atencao | positivo
  indicador        String   @db.VarChar(50)   // indicador principal avaliado
  indicador2       String?  @map("indicador2") @db.VarChar(50)  // segundo indicador (regras compostas)
  categoria        String   @db.VarChar(50)
  threshold1       Decimal? @db.Decimal(18, 6) // limite principal
  threshold2       Decimal? @db.Decimal(18, 6) // limite secundário (ex: between)
  templateMensagem String   @map("template_mensagem") @db.Text  // ex: "LC de {val}x — passivo supera ativo"
  ativo            Boolean  @default(true)
  ordem            Int      @default(0)        // ordem de exibição na tela

  @@index([severidade])
  @@index([ativo])
  @@map("credito_regras")
}

