  vlRemessas           Decimal  @default(0) @map("vl_remessas")           @db.Decimal(18, 2)
  gcsUri               String   @map("gcs_uri")
  hashArquivo          String   @map("hash_arquivo") @db.VarChar(64)
  cfopsJson            String?  @map("cfops_json")   @db.Text
  processadoEm         DateTime @default(now()) @map("processado_em")
  atualizadoEm         DateTime @updatedAt           @map("atualizado_em")

  tenant               Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, empresaId, ano, mes, fonte], name: "tenantId_empresaId_ano_mes_fonte")
  @@index([tenantId, cnpj])
  @@index([tenantId, empresaId, fonte, ano], name: "idx_fat_comp_tenant_empresa_fonte_ano")
  @@index([tenantId, cnpj, ano, fonte],      name: "idx_fat_comp_tenant_cnpj_ano_fonte")
  @@map("faturamento_competencias")
}

